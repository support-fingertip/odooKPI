<?xml version="1.0" encoding="utf-8"?>
<odoo>



    <record id="view_kpi_target_period_list" model="ir.ui.view">
        <field name="name">kpi.target.period.list</field>
        <field name="model">kpi.target.period</field>
        <field name="arch" type="xml">
            <list string="Target Periods" 
                  decoration-muted="not active">
                <field name="name"/>
                <field name="period_type" widget="badge"
                       decoration-info="period_type == 'monthly'"
                       decoration-warning="period_type == 'quarterly'"
                       decoration-success="period_type == 'yearly'"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="target_count" string="Individual Targets"/>
                <field name="team_target_count" string="Team Targets"/>
                <field name="active" widget="toggle_button"/>
            </list>
        </field>
    </record>

    <record id="view_kpi_target_period_form" model="ir.ui.view">
        <field name="name">kpi.target.period.form</field>
        <field name="model">kpi.target.period</field>
        <field name="arch" type="xml">
            <form string="Target Period">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_targets" type="object"
                                class="oe_stat_button" icon="fa-user">
                            <field name="target_count" widget="statinfo" string="Individual"/>
                        </button>
                        <button name="action_view_team_targets" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="team_target_count" widget="statinfo" string="Teams"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Period Name"/>
                        <h1><field name="name" placeholder="e.g. January 2026"/></h1>
                    </div>
                    <group>
                        <group string="Period Configuration">
                            <field name="period_type"/>
                            <field name="date_from"
                                   help="Selecting a date auto-fills the end date"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_target_period" model="ir.actions.act_window">
        <field name="name">Target Periods</field>
        <field name="res_model">kpi.target.period</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create Your First Period</p>
            <p>Define monthly, quarterly, or yearly periods to track KPI targets.</p>
        </field>
    </record>

    <record id="view_kpi_manager_target_list" model="ir.ui.view">
        <field name="name">kpi.manager.target.list</field>
        <field name="model">kpi.manager.target</field>
        <field name="arch" type="xml">
            <list string="Team Targets"
                  decoration-muted="state == 'done'"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'">
                <field name="manager_id" string="Manager / Executive"/>
                <field name="department_id" optional="show"/>
                <field name="period_id"/>
                <field name="period_type" widget="badge"
                       decoration-info="period_type == 'monthly'"
                       decoration-warning="period_type == 'quarterly'"
                       decoration-success="period_type == 'yearly'"/>
                <field name="assignment_mode" widget="badge"
                       decoration-primary="assignment_mode == 'distribute'"
                       decoration-warning="assignment_mode == 'individual'"/>
                <field name="member_count" string="Members"/>
                <field name="total_target_orders" string="Orders Target" optional="show"/>
                <field name="total_target_visits" string="Visits Target" optional="show"/>
                <field name="total_target_new_dealers" string="New Dealers Target" optional="show"/>
                <field name="team_actual_orders" string="Actual Orders" optional="show"/>
                <field name="team_actual_visits" string="Actual Visits" optional="show"/>
                <field name="team_overall_achievement" string="Achievement %" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_kpi_manager_target_form" model="ir.ui.view">
        <field name="name">kpi.manager.target.form</field>
        <field name="model">kpi.manager.target</field>
        <field name="arch" type="xml">
            <form string="Team Target">
                <header>
                    <button name="action_confirm" string="Confirm Targets" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark Done" type="object"
                            class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_member_targets" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="member_count" widget="statinfo" string="Members"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-check-circle"
                                invisible="not is_fully_allocated or assignment_mode != 'distribute'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value text-success">Fully</span>
                                <span class="o_stat_text">Allocated</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" placeholder="Team Target"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Assignment">
                            <field name="manager_id" options="{'no_create': True}"/>
                            <field name="department_id" readonly="1"/>
                            <field name="period_id"/>
                            <field name="period_type" readonly="1"/>
                        </group>
                        <group string="Mode">
                            <field name="assignment_mode" widget="radio"/>
                            <div class="text-muted" style="font-size: 12px; margin-top: 4px;">
                                <span invisible="assignment_mode != 'distribute'">
                                    <i class="fa fa-info-circle"/> Enter a total target and distribute it
                                    among team members equally or manually.
                                </span>
                                <span invisible="assignment_mode != 'individual'">
                                    <i class="fa fa-info-circle"/> Set individual targets for each team
                                    member directly in the table below.
                                </span>
                            </div>
                        </group>
                    </group>

                
                    <div invisible="assignment_mode != 'distribute'">

                        <div class="o_section_title" style="margin: 16px 0 8px 0; font-weight: 600; font-size: 14px; color: #555;">
                            Step 1: Enter Total Team Targets
                        </div>
                        <group>
                            <group>
                                <field name="total_target_orders"/>
                                <field name="total_target_visits"/>
                                <field name="total_target_new_dealers"/>
                            </group>
                            <group>
                                <field name="total_target_payment_collected"/>
                                <field name="total_target_complaints_solved"/>
                            </group>
                        </group>
                        <div class="o_section_title" style="margin: 16px 0 8px 0; font-weight: 600; font-size: 14px; color: #555;">
                            Allocation Balance (Total Target vs Sum of Member Targets)
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <table class="table table-sm table-bordered table-hover" style="font-size: 13px;">
                                    <thead class="table-primary">
                                        <tr>
                                            <th>KPI Type</th>
                                            <th class="text-end">Total Target</th>
                                            <th class="text-end">Sum Allocated</th>
                                            <th class="text-end">Remaining</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Orders</strong></td>
                                            <td class="text-end">
                                                <field name="total_target_orders" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="team_allocated_orders" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end"
                                                t-att-class="unallocated_orders > 0 ? 'text-warning' : (unallocated_orders &lt; 0 ? 'text-danger' : 'text-success')">
                                                <field name="unallocated_orders" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-success" invisible="unallocated_orders != 0">Done</span>
                                                <span class="badge bg-warning text-dark" invisible="unallocated_orders == 0 or unallocated_orders &lt;= 0">Pending</span>
                                                <span class="badge bg-danger" invisible="unallocated_orders >= 0">Over</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Visits</strong></td>
                                            <td class="text-end">
                                                <field name="total_target_visits" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="team_allocated_visits" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="unallocated_visits" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-success" invisible="unallocated_visits != 0">Done</span>
                                                <span class="badge bg-warning text-dark" invisible="unallocated_visits == 0 or unallocated_visits &lt;= 0">Pending</span>
                                                <span class="badge bg-danger" invisible="unallocated_visits >= 0">Over</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>New Dealers</strong></td>
                                            <td class="text-end">
                                                <field name="total_target_new_dealers" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="team_allocated_new_dealers" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="unallocated_new_dealers" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-success" invisible="unallocated_new_dealers != 0">Done</span>
                                                <span class="badge bg-warning text-dark" invisible="unallocated_new_dealers == 0 or unallocated_new_dealers &lt;= 0">Pending</span>
                                                <span class="badge bg-danger" invisible="unallocated_new_dealers >= 0">Over</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Payment Collected</strong></td>
                                            <td class="text-end">
                                                <field name="total_target_payment_collected" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="team_allocated_payment_collected" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-end">
                                                <field name="unallocated_payment_collected" readonly="1" nolabel="1"/>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-success" invisible="unallocated_payment_collected != 0">Done</span>
                                                <span class="badge bg-warning text-dark" invisible="unallocated_payment_collected == 0 or unallocated_payment_collected &lt;= 0">Pending</span>
                                                <span class="badge bg-danger" invisible="unallocated_payment_collected >= 0">Over</span>
                                            </td>
                                        </tr>
                                        
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>

                    <notebook>
                        <page string="Team Member Targets" name="member_targets">

                            <div class="d-flex justify-content-between align-items-center mb-2 pt-1">
                                <span class="text-muted" style="font-size: 13px;">
                                    <i class="fa fa-info-circle"/>
                                    <span invisible="assignment_mode != 'distribute'">
                                        Set each member's allocation below, then check the balance table above.
                                    </span>
                                    <span invisible="assignment_mode != 'individual'">
                                        Set individual targets for each team member below.
                                    </span>
                                </span>
                                <div class="d-flex gap-2">
                                    <button name="action_distribute_equally" type="object"
                                            string="Distribute Equally"
                                            class="btn btn-sm btn-outline-secondary"
                                            invisible="assignment_mode != 'distribute' or member_count == 0"/>
                                    <button name="action_add_member_target" type="object"
                                            string="+ Add Member Target"
                                            class="btn btn-sm btn-primary"/>
                                </div>
                            </div>

                            <field name="member_target_ids" nolabel="1">
                                <list editable="bottom" string="Member Targets"
                                      decoration-success="overall_achievement >= 100"
                                      decoration-warning="overall_achievement >= 75 and overall_achievement &lt; 100"
                                      decoration-danger="overall_achievement &gt; 0 and overall_achievement &lt; 75">
                                    <field name="employee_id" required="1" string="Employee"/>
                                    <field name="period_id" column_invisible="1"/>
                                    <field name="manager_target_id" column_invisible="1"/>
                                    <field name="target_orders" string="Orders Target"/>
                                    <field name="target_visits" string="Visits Target"/>
                                    <field name="target_new_dealers" string="New Dealers" optional="show"/>
                                    <field name="target_payment_collected" string="Payment" optional="show"/>
                                    <field name="target_complaints_solved" string="Complaints" optional="show"/>
                                    <field name="actual_orders" string="Actual Orders" readonly="1"
                                           decoration-success="actual_orders >= target_orders"
                                           decoration-danger="target_orders &gt; 0 and actual_orders &lt; target_orders"
                                           optional="show"/>
                                    <field name="actual_visits" string="Actual Visits" readonly="1"
                                           decoration-success="actual_visits >= target_visits"
                                           decoration-danger="target_visits &gt; 0 and actual_visits &lt; target_visits"
                                           optional="show"/>
                                    <field name="actual_new_dealers" string="Act. Dealers" readonly="1" optional="show"/>
                                    <field name="actual_payment_collected" string="Act. Payment" readonly="1" optional="show"/>
                                    <field name="actual_complaints_solved" string="Act. Complaints" readonly="1" optional="show"/>
                                    <field name="overall_achievement" string="Overall %" readonly="1" widget="progressbar"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-success="state == 'confirmed'"
                                           decoration-muted="state == 'done'"
                                           readonly="1" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <page string="Team Achievement Summary" name="team_achievement">
                            <group>
                                <group string="Team Actuals (Auto-computed from All Members)">
                                    <field name="team_actual_orders"/>
                                    <field name="team_actual_visits"/>
                                    <field name="team_actual_new_dealers"/>
                                    <field name="team_actual_payment_collected"/>
                                    <field name="team_actual_complaints_solved"/>
                                </group>
                                <group string="Team Achievement %">
                                    <field name="team_achievement_orders" widget="progressbar"/>
                                    <field name="team_achievement_visits" widget="progressbar"/>
                                    <field name="team_achievement_new_dealers" widget="progressbar"/>
                                    <field name="team_achievement_payment_collected" widget="progressbar"/>
                                    <field name="team_achievement_complaints_solved" widget="progressbar"/>
                                    <field name="team_overall_achievement" widget="progressbar"
                                           string="Overall Team Achievement"/>
                                </group>
                            </group>
                        </page>

                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Add any notes about this team target..."/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kpi_manager_target_search" model="ir.ui.view">
        <field name="name">kpi.manager.target.search</field>
        <field name="model">kpi.manager.target</field>
        <field name="arch" type="xml">
            <search string="Team Targets">
                <field name="manager_id" string="Manager / Executive"/>
                <field name="period_id"/>
                <field name="department_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <separator/>
                <filter string="Distribute Mode" name="distribute"
                        domain="[('assignment_mode','=','distribute')]"/>
                <filter string="Individual Mode" name="individual"
                        domain="[('assignment_mode','=','individual')]"/>
                <group expand="0" string="Group By">
                    <filter string="Manager" name="group_manager"
                            context="{'group_by': 'manager_id'}"/>
                    <filter string="Department" name="group_dept"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Period" name="group_period"
                            context="{'group_by': 'period_id'}"/>
                    <filter string="Period Type" name="group_period_type"
                            context="{'group_by': 'period_type'}"/>
                    <filter string="State" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Mode" name="group_mode"
                            context="{'group_by': 'assignment_mode'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kpi_manager_target" model="ir.actions.act_window">
        <field name="name">Team Targets</field>
        <field name="res_model">kpi.manager.target</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_kpi_manager_target_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a Team Target</p>
            <p>Assign a team target to a manager for a specific period.
                Choose to distribute the total among team members or assign individually.</p>
        </field>
    </record>


    <record id="view_kpi_target_list" model="ir.ui.view">
        <field name="name">kpi.target.list</field>
        <field name="model">kpi.target</field>
        <field name="arch" type="xml">
            <list string="Individual KPI Targets"
                  decoration-success="overall_achievement >= 100"
                  decoration-warning="overall_achievement >= 75 and overall_achievement &lt; 100"
                  decoration-danger="overall_achievement &gt; 0 and overall_achievement &lt; 75">
                <field name="employee_id" string="Employee / Executive"/>
                <field name="department_id" optional="show"/>
                <field name="period_id"/>
                <field name="period_type" widget="badge"
                       decoration-info="period_type == 'monthly'"
                       decoration-warning="period_type == 'quarterly'"
                       decoration-success="period_type == 'yearly'"
                       optional="show"/>
                <field name="manager_target_id" optional="show" string="Team"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'done'"/>
                <field name="target_orders" string="Orders Target" optional="show"/>
                <field name="target_visits" string="Visits Target" optional="show"/>
                <field name="target_new_dealers" string="New Dealers Target" optional="show"/>
                <field name="target_payment_collected" string="Payment Target" optional="show"/>
                <field name="target_complaints_solved" string="Complaints Target" optional="show"/>
                <field name="actual_orders" string="Actual Orders"
                       decoration-success="actual_orders >= target_orders and target_orders &gt; 0"
                       decoration-danger="actual_orders &lt; target_orders and target_orders &gt; 0"
                       optional="show"/>
                <field name="actual_visits" string="Actual Visits"
                       decoration-success="actual_visits >= target_visits and target_visits &gt; 0"
                       decoration-danger="actual_visits &lt; target_visits and target_visits &gt; 0"
                       optional="show"/>
                <field name="actual_new_dealers" string="Actual Dealers" optional="show"/>
                <field name="actual_payment_collected" string="Actual Payment" optional="show"/>
                <field name="actual_complaints_solved" string="Actual Complaints" optional="show"/>
                <field name="overall_achievement" string="Overall %" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_kpi_target_form" model="ir.ui.view">
        <field name="name">kpi.target.form</field>
        <field name="model">kpi.target</field>
        <field name="arch" type="xml">
            <form string="KPI Target">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark Done" type="object"
                            class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <div class="oe_stat_button" style="cursor: default;">
                            <div class="o_field_widget o_stat_info">
                                <field name="overall_achievement" widget="statinfo"
                                       string="Overall %" nolabel="1"/>
                                <span class="o_stat_text">Overall %</span>
                            </div>
                        </div>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1" placeholder="Target Reference"/></h1>
                    </div>

                    <group>
                        <group string="Assignment">
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="period_id"/>
                            <field name="period_type" readonly="1"/>
                            <field name="manager_target_id" readonly="1"
                                   invisible="not manager_target_id"
                                   string="Part of Team"/>
                        </group>
                        <group string="Achievement Summary">
                            <field name="achievement_orders" widget="progressbar" string="Orders %"/>
                            <field name="achievement_visits" widget="progressbar" string="Visits %"/>
                            <field name="achievement_new_dealers" widget="progressbar" string="New Dealers %"/>
                            <field name="achievement_payment_collected" widget="progressbar" string="Payment %"/>
                            <field name="achievement_complaints_solved" widget="progressbar" string="Complaints %"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Targets vs Actuals" name="targets_actuals">
                            <div class="row">
                                <div class="col-12">
                                    <table class="table table-bordered table-hover" style="font-size: 13px;">
                                        <thead class="table-primary">
                                            <tr>
                                                <th>KPI Type</th>
                                                <th class="text-end">Target</th>
                                                <th class="text-end">Actual</th>
                                                <th class="text-end">Achievement %</th>
                                                <th class="text-center">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td><i class="fa fa-shopping-cart me-1 text-primary"/> Orders</td>
                                                <td class="text-end">
                                                    <field name="target_orders" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="actual_orders" readonly="1" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="achievement_orders" readonly="1" nolabel="1" widget="progressbar"/>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success" invisible="achievement_orders &lt; 100 or target_orders == 0">Achieved</span>
                                                    <span class="badge bg-warning text-dark" invisible="achievement_orders &lt; 75 or achievement_orders >= 100">Near</span>
                                                    <span class="badge bg-danger" invisible="achievement_orders >= 75 or target_orders == 0">Low</span>
                                                    <span class="badge bg-secondary" invisible="target_orders != 0">No Target</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td><i class="fa fa-map-marker me-1 text-info"/> Visits</td>
                                                <td class="text-end">
                                                    <field name="target_visits" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="actual_visits" readonly="1" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="achievement_visits" readonly="1" nolabel="1" widget="progressbar"/>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success" invisible="achievement_visits &lt; 100 or target_visits == 0">Achieved</span>
                                                    <span class="badge bg-warning text-dark" invisible="achievement_visits &lt; 75 or achievement_visits >= 100">Near</span>
                                                    <span class="badge bg-danger" invisible="achievement_visits >= 75 or target_visits == 0">Low</span>
                                                    <span class="badge bg-secondary" invisible="target_visits != 0">No Target</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td><i class="fa fa-handshake-o me-1 text-success"/> New Dealers</td>
                                                <td class="text-end">
                                                    <field name="target_new_dealers" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="actual_new_dealers" readonly="1" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="achievement_new_dealers" readonly="1" nolabel="1" widget="progressbar"/>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success" invisible="achievement_new_dealers &lt; 100 or target_new_dealers == 0">Achieved</span>
                                                    <span class="badge bg-warning text-dark" invisible="achievement_new_dealers &lt; 75 or achievement_new_dealers >= 100">Near</span>
                                                    <span class="badge bg-danger" invisible="achievement_new_dealers >= 75 or target_new_dealers == 0">Low</span>
                                                    <span class="badge bg-secondary" invisible="target_new_dealers != 0">No Target</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td><i class="fa fa-money me-1 text-warning"/> Payment Collected</td>
                                                <td class="text-end">
                                                    <field name="target_payment_collected" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="actual_payment_collected" readonly="1" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="achievement_payment_collected" readonly="1" nolabel="1" widget="progressbar"/>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success" invisible="achievement_payment_collected &lt; 100 or target_payment_collected == 0">Achieved</span>
                                                    <span class="badge bg-warning text-dark" invisible="achievement_payment_collected &lt; 75 or achievement_payment_collected >= 100">Near</span>
                                                    <span class="badge bg-danger" invisible="achievement_payment_collected >= 75 or target_payment_collected == 0">Low</span>
                                                    <span class="badge bg-secondary" invisible="target_payment_collected != 0">No Target</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td><i class="fa fa-check-square-o me-1 text-danger"/> Complaints Solved</td>
                                                <td class="text-end">
                                                    <field name="target_complaints_solved" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="actual_complaints_solved" readonly="1" nolabel="1"/>
                                                </td>
                                                <td class="text-end">
                                                    <field name="achievement_complaints_solved" readonly="1" nolabel="1" widget="progressbar"/>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success" invisible="achievement_complaints_solved &lt; 100 or target_complaints_solved == 0">Achieved</span>
                                                    <span class="badge bg-warning text-dark" invisible="achievement_complaints_solved &lt; 75 or achievement_complaints_solved >= 100">Near</span>
                                                    <span class="badge bg-danger" invisible="achievement_complaints_solved >= 75 or target_complaints_solved == 0">Low</span>
                                                    <span class="badge bg-secondary" invisible="target_complaints_solved != 0">No Target</span>
                                                </td>
                                            </tr>
                                        </tbody>
                                        <tfoot class="table-secondary">
                                            <tr>
                                                <td colspan="3"><strong>Overall Achievement</strong></td>
                                                <td class="text-end" colspan="2">
                                                    <field name="overall_achievement" readonly="1" nolabel="1" widget="progressbar"/>
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                            <div class="alert alert-light border" role="alert" style="margin-top: 8px; font-size: 12px;">
                                <i class="fa fa-database text-primary me-1"/>
                                <strong>Data sources:</strong>
                                <ul style="margin: 6px 0 0 0; padding-left: 18px;">
                                    <li><strong>Visits</strong> — completed visits in the period (<code>visit.model</code>, status=completed)</li>
                                    <li><strong>Orders</strong> — all sale orders in the period (<code>sale.order</code>, date_order in period)</li>
                                    <li><strong>New Dealers</strong> — <em>add manually in the tab below</em></li>
                                    <li><strong>Payment Collected</strong> — <em>add manually in the tab below</em></li>
                                    <li><strong>Complaints Solved</strong> — <em>add manually in the tab below</em></li>
                                </ul>
                            </div>
                        </page>

                        <page string="Manual Actual Entries" name="actual_entries">
                            <div class="alert alert-warning" role="alert" style="margin-bottom: 12px;">
                                <i class="fa fa-exclamation-triangle me-1"/>
                                <strong>New Dealers</strong>, <strong>Payment Collected</strong>, and
                                <strong>Complaints Solved</strong> require manual entries here.
                                <strong>Visits</strong> are auto-computed from completed visit records
                                and <strong>Orders</strong> are auto-computed from all sale orders in the period.
                                To add or correct a value, add an entry below — the higher value will be used.
                            </div>
                            <field name="actual_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="kpi_type"/>
                                    <field name="value"/>
                                    <field name="notes" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kpi_target_search" model="ir.ui.view">
        <field name="name">kpi.target.search</field>
        <field name="model">kpi.target</field>
        <field name="arch" type="xml">
            <search string="Individual KPI Targets">
                <field name="employee_id" string="Employee / Executive"/>
                <field name="period_id"/>
                <field name="department_id"/>
                <field name="manager_target_id" string="Team Target"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <separator/>
                <filter string="Individual Only (No Team)" name="standalone"
                        domain="[('manager_target_id','=',False)]"/>
                <filter string="Team Members" name="team_members"
                        domain="[('manager_target_id','!=',False)]"/>
                <separator/>
                <filter string="Monthly" name="monthly" domain="[('period_type','=','monthly')]"/>
                <filter string="Quarterly" name="quarterly" domain="[('period_type','=','quarterly')]"/>
                <filter string="Yearly" name="yearly" domain="[('period_type','=','yearly')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_dept"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Period" name="group_period"
                            context="{'group_by': 'period_id'}"/>
                    <filter string="Period Type" name="group_period_type"
                            context="{'group_by': 'period_type'}"/>
                    <filter string="Team Target" name="group_team"
                            context="{'group_by': 'manager_target_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kpi_target" model="ir.actions.act_window">
        <field name="name">Individual KPI Targets</field>
        <field name="res_model">kpi.target</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_kpi_target_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create an Individual KPI Target</p>
            <p>Assign KPI targets directly to an employee/executive for a specific period.
                To manage team targets with distribution, use <strong>Team Targets</strong> instead.</p>
        </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════════════════════
         KPI ACTUAL VIEWS
    ═══════════════════════════════════════════════════════════════════════════ -->

    <record id="view_kpi_actual_list" model="ir.ui.view">
        <field name="name">kpi.actual.list</field>
        <field name="model">kpi.actual</field>
        <field name="arch" type="xml">
            <list string="KPI Actual Entries" editable="bottom">
                <field name="date"/>
                <field name="employee_id" string="Employee"/>
                <field name="target_id" string="Target Period"/>
                <field name="kpi_type"/>
                <field name="value"/>
                <field name="notes" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_kpi_actual_search" model="ir.ui.view">
        <field name="name">kpi.actual.search</field>
        <field name="model">kpi.actual</field>
        <field name="arch" type="xml">
            <search string="KPI Actual Entries">
                <field name="employee_id"/>
                <field name="target_id"/>
                <field name="kpi_type"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_emp" context="{'group_by': 'employee_id'}"/>
                    <filter string="KPI Type" name="group_type" context="{'group_by': 'kpi_type'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kpi_actual" model="ir.actions.act_window">
        <field name="name">KPI Actual Entries</field>
        <field name="res_model">kpi.actual</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_kpi_actual_search"/>
    </record>


    <record id="action_kpi_dashboard" model="ir.actions.client">
        <field name="name">KPI Dashboard</field>
        <field name="tag">kpi_target_dashboard</field>
    </record>

</odoo>
