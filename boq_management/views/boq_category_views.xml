<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         BOQ CATEGORY — List View
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_boq_category_list" model="ir.ui.view">
        <field name="name">boq.category.list</field>
        <field name="model">boq.category</field>
        <field name="arch" type="xml">
            <list string="Work Categories" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="icon"/>
                <field name="boq_count" string="BOQs"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         BOQ CATEGORY — Form View
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_boq_category_form" model="ir.ui.view">
        <field name="name">boq.category.form</field>
        <field name="model">boq.category</field>
        <field name="arch" type="xml">
            <form string="Work Category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(boq_management.action_boq_boq)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="boq_count" widget="statinfo" string="BOQs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Category Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Electrical"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. electrical"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="icon" placeholder="fa-bolt"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Optional description…"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         BOQ CATEGORY — Kanban View
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_boq_category_kanban" model="ir.ui.view">
        <field name="name">boq.category.kanban</field>
        <field name="model">boq.category</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile boq_category_kanban">
                <field name="name"/>
                <field name="code"/>
                <field name="icon"/>
                <field name="color"/>
                <field name="boq_count"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="boq_cat_card color_#{record.color.raw_value}">
                            <div class="boq_cat_icon">
                                <i t-attf-class="fa #{record.icon.value} fa-2x"/>
                            </div>
                            <div class="boq_cat_info">
                                <strong><field name="name"/></strong>
                                <span class="text-muted small">
                                    <field name="boq_count"/> BOQs
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         BOQ CATEGORY — Action
    ═══════════════════════════════════════════════════════════════ -->
    <record id="action_boq_category" model="ir.actions.act_window">
        <field name="name">Work Categories</field>
        <field name="res_model">boq.category</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first work category!
            </p>
            <p>
                Work categories (Electrical, Civil, Lighting, Plumbing…) appear
                as tabs on every BOQ form. Only the selected categories are shown.
            </p>
        </field>
    </record>

</odoo>
