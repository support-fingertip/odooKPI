
<templates xml:space="preserve">

    <t t-name="employee_dashboard.OrdersList">

        <div style="flex: 1; display: flex; flex-direction: column; height: 100%; min-height: 0; overflow: hidden;">

            <div class="d-flex gap-3 mb-3 align-items-end" style="flex-shrink: 0; align-items: flex-end;">
                <div style="flex: 1 1 150px;">
                    <label>Customer</label>
                    <input type="text"
                           t-model="state.orderFilter.customer"
                           style="height: 38px;"
                           class="form-control"
                           placeholder="Search Customer..."
                           t-on-input="applyOrderFilters" />
                </div>

                <div style="flex: 1 1 150px;">
                    <label>From Date</label>
                    <input type="date"
                           t-model="state.orderFilter.from_date"
                           style="height: 38px;"
                           class="form-control"
                           t-on-change="applyOrderFilters" />
                </div>

                <div style="flex: 1 1 150px;">
                    <label>End Date</label>
                    <input type="date"
                           t-model="state.orderFilter.to_date"
                           style="height: 38px;"
                           class="form-control"
                           t-on-change="applyOrderFilters" />
                </div>

                <div style="flex: 1 1 150px;">
                    <label>Status</label>
                    <select
                            t-model="state.orderFilter.status"
                            style="height: 38px;"
                            class="form-control"
                            t-on-change="applyOrderFilters">
                        <option value="">All</option>
                        <option value="draft">Draft</option>
                        <option value="sent">Sent</option>
                        <option value="sale">Sale</option>
                        <option value="cancel">Cancelled</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive" style="flex: 1; min-height: 0; overflow-y: auto; overflow-x: auto;">
                <table class="table table-responsive table-sm" id="orderTable">
                    <thead style="background-color: #007bff; color: #fff; position: sticky; top: 0; z-index: 10;">
                        <tr><th>Order ID</th><th>Outlet</th><th>Date</th><th>Status</th><th>Amount</th><th>Items</th><th style="width: 80px;">Details</th></tr>
                    </thead>
                    <t t-if="state.orders">
                        <tbody>
                            <t t-foreach="state.orders" t-as="l" t-key="l.id">
                                <tr style="cursor: pointer;" t-on-click="() => this.toggleOrderDetails(l.id, l.order_line)"
                                    t-att-class="state.expandedOrderId === l.id ? 'table-primary' : ''">
                                    <td><t t-esc="l.name"/></td>
                                    <td><t t-esc="l.partner_id and l.partner_id[1]"/></td>
                                    <td><t t-esc="l.date_order"/></td>
                                    <td><t t-esc="l.state"/></td>
                                    <td><t t-esc="l.amount_total"/></td>
                                    <td><t t-esc="l.item_count"/></td>
                                    <td class="text-center">
                                        <i t-attf-class="fa {{state.expandedOrderId === l.id ? 'fa-chevron-up' : 'fa-chevron-down'}}"></i>
                                    </td>
                                </tr>
                                <t t-if="state.expandedOrderId === l.id">
                                    <tr>
                                        <td colspan="7" class="p-0">
                                            <div class="bg-light p-3">
                                                <h6 class="mb-2"><i class="fa fa-list me-1"></i> Order Items - <t t-esc="l.name"/></h6>
                                                <t t-if="state.expandedOrderLines.length > 0">
                                                    <table class="table table-sm table-bordered mb-0">
                                                        <thead class="table-secondary">
                                                            <tr>
                                                                <th style="width: 40px;">#</th>
                                                                <th>Product</th>
                                                                <th class="text-center" style="width: 80px;">Qty</th>
                                                                <th class="text-end" style="width: 100px;">Unit Price</th>
                                                                <th class="text-end" style="width: 100px;">Subtotal</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.expandedOrderLines" t-as="line" t-key="line.id">
                                                                <tr>
                                                                    <td><t t-esc="line_index + 1"/></td>
                                                                    <td><t t-esc="line.product_id ? line.product_id[1] : line.name"/></td>
                                                                    <td class="text-center"><t t-esc="line.product_uom_qty"/></td>
                                                                    <td class="text-end"><t t-esc="line.price_unit.toFixed(2)"/></td>
                                                                    <td class="text-end"><strong><t t-esc="line.price_subtotal.toFixed(2)"/></strong></td>
                                                                </tr>
                                                            </t>
                                                        </tbody>
                                                        <tfoot class="table-secondary">
                                                            <tr>
                                                                <td colspan="4" class="text-end"><strong>Total:</strong></td>
                                                                <td class="text-end"><strong><t t-esc="l.amount_total.toFixed(2)"/></strong></td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </t>
                                                <t t-else="">
                                                    <div class="text-muted text-center py-2">
                                                        <i class="fa fa-inbox me-1"></i> No items in this order
                                                    </div>
                                                </t>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </t>
                    <t t-else="">
                        <tbody>
                            <tr>
                                <td class="text-center" colspan="7">No active Orders</td>
                            </tr>
                        </tbody>
                    </t>
                </table>
            </div>

        </div>

    </t>

</templates>

