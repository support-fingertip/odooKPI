<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== PJP MODEL VIEWS ==================== -->

    <!-- PJP List View -->
    <record id="view_pjp_model_list" model="ir.ui.view">
        <field name="name">pjp.model.list</field>
        <field name="model">pjp.model</field>
        <field name="arch" type="xml">
            <list string="PJPs" decoration-success="state == 'approved'" 
                  decoration-info="state == 'active'"
                  decoration-muted="state == 'completed'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'approved'"
                       decoration-info="state == 'active'"
                       decoration-warning="state == 'draft'"
                       decoration-muted="state in ['completed', 'cancelled']"/>
            </list>
        </field>
    </record>

    <!-- PJP Form View -->
    <record id="view_pjp_model_form" model="ir.ui.view">
        <field name="name">pjp.model.form</field>
        <field name="model">pjp.model</field>
        <field name="arch" type="xml">
            <form string="PJP">
                <header>
                    <button name="action_approve" string="Approve" 
                            type="object" class="oe_highlight" 
                            invisible="state != 'draft'"/>
                    <button name="action_activate" string="Activate" 
                            type="object" class="oe_highlight" 
                            invisible="state != 'approved'"/>
                    <button name="action_complete" string="Complete" 
                            type="object" 
                            invisible="state not in ['active', 'approved']"/>
                    <button name="action_cancel" string="Cancel" 
                            type="object" 
                            invisible="state in ['completed', 'cancelled']"/>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,approved,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="PJP Information">
                            <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        
                        
                    </group>
                    
                    <notebook>
                        <page string="PJP Items" name="pjp_items">
                            <field name="pjp_item_ids">
                                <list string="PJP Items" editable="bottom">
                                    <field name="date"/>
                                    <field name="sequence"/>
                                    <field name="assigned_beat_id"/>
                                    <field name="approved_beat_id"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'approved'"
                                           decoration-info="status == 'completed'"
                                           decoration-warning="status == 'draft'"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Add notes about this PJP..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- PJP Search View -->
    <record id="view_pjp_model_search" model="ir.ui.view">
        <field name="name">pjp.model.search</field>
        <field name="model">pjp.model</field>
        <field name="arch" type="xml">
            <search string="PJPs">
                <field name="name"/>
                <field name="employee_id"/>
                
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                
                <separator/>
                <filter string="Current Month" name="current_month" 
                        domain="[('start_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Start Date" name="group_start_date" context="{'group_by': 'start_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- PJP Kanban View -->
    <record id="view_pjp_model_kanban" model="ir.ui.view">
        <field name="name">pjp.model.kanban</field>
        <field name="model">pjp.model</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id"/>
                                    </strong>
                                </div>
                                <span class="badge" t-attf-class="badge-#{record.state.raw_value == 'approved' ? 'success' : record.state.raw_value == 'active' ? 'info' : 'warning'}">
                                    <field name="state"/>
                                </span>
                            </div>
                           
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- PJP Action -->
    <record id="action_pjp_model" model="ir.actions.act_window">
        <field name="name">PJP</field>
        <field name="res_model">pjp.model</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first PJP!
            </p>
        </field>
    </record>

    
    <!-- Menu Items -->
    <menuitem id="menu_pjp_root" 
              name="PJP" 
            parent="hr.menu_hr_root" 
            action="action_pjp_model" 
             active="False"
              sequence="15"/>
    
    
    
   
</odoo>