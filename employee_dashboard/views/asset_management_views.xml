<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         ASSET MASTER — Admin-configurable catalogue of asset types
         ============================================================ -->

    <record id="view_asset_master_list" model="ir.ui.view">
        <field name="name">asset.master.list</field>
        <field name="model">asset.master</field>
        <field name="arch" type="xml">
            <list string="Asset Masters" decoration-muted="not active">
                <field name="name"/>
                <field name="asset_type"/>
                <field name="code"/>
                <field name="customer_count" string="Assigned (Active)"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_asset_master_form" model="ir.ui.view">
        <field name="name">asset.master.form</field>
        <field name="model">asset.master</field>
        <field name="arch" type="xml">
            <form string="Asset Master">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Asset Name"/>
                        <h1><field name="name" placeholder="e.g. Visi-Cooler 300L"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_type"/>
                            <field name="code"/>
                            <field name="customer_count" string="Assigned (Active)" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image" widget="image" options="{'size': [128, 128]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description &amp; Notes">
                            <field name="description" placeholder="Describe the asset…"/>
                            <field name="notes" placeholder="Additional notes…"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asset_master" model="ir.actions.act_window">
        <field name="name">Asset Master</field>
        <field name="res_model">asset.master</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No asset types configured yet.
            </p>
            <p>Create asset types like Freezers, Hoardings, Vehicles that
               the company assigns to customers for promotional purposes.</p>
        </field>
    </record>

    <!-- ============================================================
         CUSTOMER ASSET — Assets given to specific customers
         ============================================================ -->

    <record id="view_customer_asset_list" model="ir.ui.view">
        <field name="name">customer.asset.list</field>
        <field name="model">customer.asset</field>
        <field name="arch" type="xml">
            <list string="Customer Assets"
                  decoration-success="state == 'assigned'"
                  decoration-warning="state == 'damaged'"
                  decoration-danger="state == 'lost'"
                  decoration-muted="state == 'returned'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="asset_master_id"/>
                <field name="asset_type"/>
                <field name="serial_number"/>
                <field name="installation_date"/>
                <field name="employee_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'assigned'"
                       decoration-warning="state == 'damaged'"
                       decoration-danger="state == 'lost'"
                       decoration-muted="state == 'returned'"/>
                <field name="open_issue_count" string="Open Issues"/>
                <field name="return_date" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_customer_asset_form" model="ir.ui.view">
        <field name="name">customer.asset.form</field>
        <field name="model">customer.asset</field>
        <field name="arch" type="xml">
            <form string="Customer Asset">
                <header>
                    <button name="action_return"
                            type="object"
                            string="Mark as Returned"
                            class="btn-secondary"
                            invisible="state != 'assigned'"/>
                    <button name="action_mark_damaged"
                            type="object"
                            string="Mark as Damaged"
                            class="btn-warning"
                            invisible="state not in ('assigned', 'returned')"/>
                    <button name="action_mark_lost"
                            type="object"
                            string="Mark as Lost"
                            class="btn-danger"
                            invisible="state not in ('assigned', 'returned')"/>
                    <button name="action_reassign"
                            type="object"
                            string="Re-Assign"
                            class="btn-success"
                            invisible="state == 'assigned'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="assigned,returned,damaged"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_issues"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-exclamation-circle">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="open_issue_count"/>
                                </span>
                                <span class="o_stat_text">Open Issues</span>
                            </div>
                        </button>
                        <button name="action_view_issues"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="issue_count"/>
                                </span>
                                <span class="o_stat_text">Total Issues</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Asset ID"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Asset Details">
                            <field name="asset_master_id"/>
                            <field name="asset_type" readonly="1"/>
                            <field name="serial_number"/>
                        </group>
                        <group string="Assignment Info">
                            <field name="partner_id"/>
                            <field name="employee_id"/>
                            <field name="visit_id"/>
                            <field name="installation_date"/>
                            <field name="return_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Issues" name="issues">
                            <field name="issue_ids" mode="list" readonly="1">
                                <list decoration-danger="priority == 'Critical'"
                                      decoration-warning="priority == 'High'"
                                      decoration-success="state in ('resolved','closed')">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="subject"/>
                                    <field name="case_type"/>
                                    <field name="priority"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Photo &amp; Notes">
                            <group>
                                <field name="image" widget="image" options="{'size': [256, 256]}"/>
                            </group>
                            <field name="notes" placeholder="Additional notes about this asset…"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_customer_asset_search" model="ir.ui.view">
        <field name="name">customer.asset.search</field>
        <field name="model">customer.asset</field>
        <field name="arch" type="xml">
            <search string="Customer Assets">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="asset_master_id"/>
                <field name="serial_number"/>
                <field name="employee_id"/>
                <filter string="Assigned" name="assigned" domain="[('state','=','assigned')]"/>
                <filter string="Returned" name="returned" domain="[('state','=','returned')]"/>
                <filter string="Damaged" name="damaged" domain="[('state','=','damaged')]"/>
                <filter string="Lost" name="lost" domain="[('state','=','lost')]"/>
                <filter string="Has Open Issues" name="has_issues" domain="[('open_issue_count','>',0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="by_customer" context="{'group_by': 'partner_id'}"/>
                    <filter string="Asset Type" name="by_type" context="{'group_by': 'asset_master_id'}"/>
                    <filter string="Status" name="by_state" context="{'group_by': 'state'}"/>
                    <filter string="Employee" name="by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Month" name="by_month" context="{'group_by': 'installation_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_customer_asset" model="ir.actions.act_window">
        <field name="name">Customer Assets</field>
        <field name="res_model">customer.asset</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_assigned': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No assets assigned yet.
            </p>
            <p>Register assets (Freezers, Hoardings, Vehicles) given to customers
               for promotional purposes and track their status and issues.</p>
        </field>
    </record>

    <!-- ============================================================
         ASSET ISSUE — Issues / service cases for customer assets
         ============================================================ -->

    <record id="view_asset_issue_list" model="ir.ui.view">
        <field name="name">asset.issue.list</field>
        <field name="model">asset.issue</field>
        <field name="arch" type="xml">
            <list string="Asset Issues"
                  decoration-danger="priority == 'Critical'"
                  decoration-warning="priority == 'High'"
                  decoration-success="state in ('resolved', 'closed')"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="customer_asset_id"/>
                <field name="asset_master_id"/>
                <field name="subject"/>
                <field name="case_type"/>
                <field name="priority" widget="badge"
                       decoration-danger="priority == 'Critical'"
                       decoration-warning="priority == 'High'"
                       decoration-info="priority == 'Medium'"
                       decoration-muted="priority == 'Low'"/>
                <field name="employee_id"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'open'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state in ('resolved','closed')"/>
            </list>
        </field>
    </record>

    <record id="view_asset_issue_form" model="ir.ui.view">
        <field name="name">asset.issue.form</field>
        <field name="model">asset.issue</field>
        <field name="arch" type="xml">
            <form string="Asset Issue">
                <header>
                    <button name="action_start"
                            type="object"
                            string="Start Working"
                            class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_resolve"
                            type="object"
                            string="Mark Resolved"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_close"
                            type="object"
                            string="Close"
                            class="btn-secondary"
                            invisible="state != 'resolved'"/>
                    <button name="action_reopen"
                            type="object"
                            string="Reopen"
                            class="btn-warning"
                            invisible="state not in ('resolved','closed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Issue ID"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Issue Details">
                            <field name="customer_asset_id"/>
                            <field name="asset_master_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="visit_id"/>
                        </group>
                        <group string="Reported By">
                            <field name="date"/>
                            <field name="employee_id"/>
                            <field name="case_type"/>
                            <field name="priority"/>
                        </group>
                    </group>
                    <group string="Issue Description">
                        <field name="subject" readonly="state in ('resolved','closed')"/>
                        <field name="description"
                               placeholder="Describe the issue in detail…"
                               readonly="state in ('resolved','closed')"/>
                    </group>
                    <notebook>
                        <page string="Resolution" name="resolution">
                            <group>
                                <field name="resolved_date" readonly="1"/>
                                <field name="resolved_by" readonly="1"/>
                            </group>
                            <field name="resolution_notes"
                                   placeholder="Describe how the issue was resolved…"/>
                        </page>
                        <page string="Attachment" name="attachment">
                            <field name="image" widget="image" options="{'size': [256, 256]}"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_asset_issue_search" model="ir.ui.view">
        <field name="name">asset.issue.search</field>
        <field name="model">asset.issue</field>
        <field name="arch" type="xml">
            <search string="Asset Issues">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="customer_asset_id"/>
                <field name="subject"/>
                <field name="employee_id"/>
                <filter string="Open" name="open" domain="[('state','=','open')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state','=','in_progress')]"/>
                <filter string="Resolved" name="resolved" domain="[('state','=','resolved')]"/>
                <filter string="Critical" name="critical" domain="[('priority','=','Critical')]"/>
                <filter string="High Priority" name="high" domain="[('priority','=','High')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="by_customer" context="{'group_by': 'partner_id'}"/>
                    <filter string="Asset" name="by_asset" context="{'group_by': 'customer_asset_id'}"/>
                    <filter string="Case Type" name="by_type" context="{'group_by': 'case_type'}"/>
                    <filter string="Priority" name="by_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Status" name="by_state" context="{'group_by': 'state'}"/>
                    <filter string="Employee" name="by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Month" name="by_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_asset_issue" model="ir.actions.act_window">
        <field name="name">Asset Issues</field>
        <field name="res_model">asset.issue</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No asset issues logged yet.
            </p>
            <p>Log issues for customer assets — maintenance requests, damage reports,
               relocation requests and more.</p>
        </field>
    </record>

    <!-- ============================================================
         MENU ITEMS — integrated into the existing emp360 menu tree
         ============================================================ -->

    <!-- Sub-menu under Reports (visible to managers) -->
    <menuitem id="menu_customer_assets"
              name="Customer Assets"
              parent="employee_dashboard.menu_emp360_reports"
              action="action_customer_asset"
              sequence="25"
              groups="employee_dashboard.group_employee_dashboard_manager"/>

    <menuitem id="menu_asset_issues"
              name="Asset Issues"
              parent="employee_dashboard.menu_emp360_reports"
              action="action_asset_issue"
              sequence="26"
              groups="employee_dashboard.group_employee_dashboard_manager"/>

    <!-- Configuration sub-menu (managers only) -->
    <menuitem id="menu_asset_master"
              name="Asset Master"
              parent="employee_dashboard.menu_emp360_configuration"
              action="action_asset_master"
              sequence="30"
              groups="employee_dashboard.group_employee_dashboard_manager"/>

</odoo>
