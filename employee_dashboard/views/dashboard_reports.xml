            <graph string="PJP by Status" type="pie">
                <field name="state" type="row"/>
            </graph>
        </field>
    </record>

    <!-- 26. PJP Count by Employee and Status (Bar) -->
    <record id="view_pjp_graph_by_employee" model="ir.ui.view">
