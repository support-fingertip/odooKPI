    <!-- PJP Analytics Action -->
    <record id="action_pjp_analytics" model="ir.actions.act_window">
        <field name="name">PJP Analytics</field>
        <field name="res_model">pjp.model</field>
        <field name="view_mode">graph,pivot,list,form</field>
        <field name="view_id" ref="view_pjp_graph_by_employee"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No PJP records found.
            </p>
        </field>
    </record>

    <!-- Analytics menu items have been moved to Employee 360 navbar.
         See views/main_menu.xml (menu_emp360_analytics_dashboard).
         The standalone Beat Management "Analytics" submenu is removed. -->

</odoo>
