        <field name="arch" type="xml">
            <graph string="PJP by Employee and Status" type="bar">
                <field name="employee_id" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- 27. PJP Monthly Trend (Line) -->
    <record id="view_pjp_graph_monthly_trend" model="ir.ui.view">
        <field name="name">pjp.model.graph.monthly</field>
        <field name="model">pjp.model</field>
        <field name="arch" type="xml">
            <graph string="PJP Monthly Creation Trend" type="line">
