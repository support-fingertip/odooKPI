<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Visit Collection ───────────────────────────────────── -->
    <record id="view_visit_collection_list" model="ir.ui.view">
        <field name="name">visit.collection.list</field>
        <field name="model">visit.collection</field>
        <field name="arch" type="xml">
            <list string="Collections" default_order="date desc"
                  decoration-success="state=='confirmed'"
                  decoration-danger="state=='cancelled'"
                  decoration-muted="state=='draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="employee_id"/>
                <field name="visit_id"/>
                <field name="amount"/>
                <field name="payment_mode"/>
                <field name="reference"/>
                <field name="state"/>
                <field name="payment_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_visit_collection_form" model="ir.ui.view">
        <field name="name">visit.collection.form</field>
        <field name="model">visit.collection</field>
        <field name="arch" type="xml">
            <form string="Collection">
                <header>
                    <button name="action_confirm" string="Confirm &amp; Post Payment"
                            type="object" class="btn-primary"
                                  invisible="state != 'draft'"
                          />
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-danger"
                            invisible="state not in  ['draft','confirmed']"
                         />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="visit_id"/>
                            <field name="partner_id"/>
                            <field name="employee_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="payment_mode"/>
                            <field name="reference"/>
                            <field name="payment_id" 
                             invisible="payment_id == False"
                            />
                        </group>
                    </group>
                    <field name="remarks" placeholder="Remarks..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_visit_collection" model="ir.actions.act_window">
        <field name="name">Collections</field>
        <field name="res_model">visit.collection</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_visit_collection"
              name="Collections"
              action="action_visit_collection"
              parent="employee_dashboard.menu_employee_dashboard_reports"
              sequence="55"/>
</odoo>
