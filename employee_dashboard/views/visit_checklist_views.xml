<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Checklist Template ─────────────────────────────────── -->
    <record id="view_checklist_template_form" model="ir.ui.view">
        <field name="name">checklist.template.form</field>
        <field name="model">checklist.template</field>
        <field name="arch" type="xml">
            <form string="Checklist Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <field name="item_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="question"/>
                            <field name="requires_photo"/>
                            <field name="active"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_checklist_template_list" model="ir.ui.view">
        <field name="name">checklist.template.list</field>
        <field name="model">checklist.template</field>
        <field name="arch" type="xml">
            <list string="Checklist Templates">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_checklist_template" model="ir.actions.act_window">
        <field name="name">Checklist Templates</field>
        <field name="res_model">checklist.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Visit Checklist Responses ─────────────────────────── -->
    <record id="view_visit_checklist_list" model="ir.ui.view">
        <field name="name">visit.checklist.list</field>
        <field name="model">visit.checklist</field>
        <field name="arch" type="xml">
            <list string="Checklist Responses"
                  decoration-success="answer==True">
                <field name="visit_id"/>
                <field name="partner_id"/>
                <field name="employee_id"/>
                <field name="question"/>
                <field name="answer" string="Done"/>
                <field name="requires_photo"/>
            </list>
        </field>
    </record>

    <record id="action_visit_checklist" model="ir.actions.act_window">
        <field name="name">Checklist Compliance</field>
        <field name="res_model">visit.checklist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_checklist_template"
              name="Checklist Templates"
              action="action_checklist_template"
              parent="employee_dashboard.menu_employee_dashboard_config"
              sequence="40"/>

    <menuitem id="menu_visit_checklist"
              name="Checklist Compliance"
              action="action_visit_checklist"
              parent="employee_dashboard.menu_employee_dashboard_reports"
              sequence="75"/>
</odoo>
