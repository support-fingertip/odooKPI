<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <record id="view_employee_form_inherit_beat" model="ir.ui.view">
    <field name="name">hr.employee.form.inherit.beat</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">
        <xpath expr="//notebook/page[@name='public']" position="inside">
            <group>
                <field name="joining_date"/>
                <field name="relieving_date"/>
                <field name="pan_number"/>
                <field name="aadhar_number"/>
            </group>
        </xpath>
    </field>
</record>
</odoo>