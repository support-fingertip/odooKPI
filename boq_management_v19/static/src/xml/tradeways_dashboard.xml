<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!--
    Tradeways Dashboard Template — Task 4
    Vendor rating summary, star display, history notebook — mirrors BOQ dashboard style.
-->
<t t-name="boq_management_v19.TradewysDashboard">
    <div class="tw_dashboard o_action"
         style="display:flex;flex-direction:column;height:100%;color-scheme:light;">

        <!-- ── LOADING ────────────────────────────────────────────────── -->
        <t t-if="state.loading">
            <div class="d-flex flex-column align-items-center justify-content-center"
                 style="flex:1;min-height:0;">
                <div class="spinner-border text-primary mb-3" role="status"
                     style="width:3rem;height:3rem;">
                    <span class="visually-hidden">Loading…</span>
                </div>
                <p class="text-muted">Loading Tradeways dashboard…</p>
            </div>
        </t>

        <!-- ── ERROR ──────────────────────────────────────────────────── -->
        <t t-elif="state.error">
            <div class="alert alert-danger m-4">
                <i class="fa fa-exclamation-triangle me-2"/>
                <strong>Dashboard Error:</strong>
                <t t-esc="state.error"/>
                <button class="btn btn-sm btn-outline-danger ms-3"
                        t-on-click="refresh">Retry</button>
            </div>
        </t>

        <!-- ── MAIN DASHBOARD ─────────────────────────────────────────── -->
        <t t-else="">

            <!-- ╔══════════════════════════════════════════════════════╗
                 ║  PAGE HEADER  (pinned, no scroll)                    ║
                 ╚══════════════════════════════════════════════════════╝ -->
            <div class="tw_dash_header d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <div class="d-flex align-items-center gap-3">
                    <i class="fa fa-handshake-o fa-2x text-primary"/>
                    <div>
                        <h4 class="mb-0 fw-bold">Tradeways Dashboard</h4>
                        <small class="text-muted">Trade vendor ratings &amp; performance summary</small>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-primary" t-on-click="openAllVendors">
                        <i class="fa fa-users me-1"/>All Vendors
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="openAllRatings">
                        <i class="fa fa-star me-1"/>All Ratings
                    </button>
                    <button class="btn btn-sm btn-light" t-on-click="refresh">
                        <i class="fa fa-refresh me-1"/>Refresh
                    </button>
                </div>
            </div>

            <!-- ╔══════════════════════════════════════════════════════╗
                 ║  SCROLLABLE BODY                                      ║
                 ╚══════════════════════════════════════════════════════╝ -->
            <div class="tw_dash_scroll" t-ref="scrollContainer">

                <!-- ── STAT CARDS ─────────────────────────────────── -->
                <div class="tw_dash_stat_row d-flex flex-wrap gap-3 p-4">

                    <!-- Total Vendors -->
                    <div class="tw_stat_card flex-fill" t-on-click="openAllVendors" style="cursor:pointer;">
                        <div class="tw_stat_icon bg-primary-subtle text-primary">
                            <i class="fa fa-users fa-2x"/>
                        </div>
                        <div class="tw_stat_body">
                            <div class="tw_stat_value"><t t-esc="state.stats.total_vendors || 0"/></div>
                            <div class="tw_stat_label">Total Vendors</div>
                        </div>
                    </div>

                    <!-- Active -->
                    <div class="tw_stat_card flex-fill">
                        <div class="tw_stat_icon bg-success-subtle text-success">
                            <i class="fa fa-check-circle fa-2x"/>
                        </div>
                        <div class="tw_stat_body">
                            <div class="tw_stat_value"><t t-esc="state.stats.active_vendors || 0"/></div>
                            <div class="tw_stat_label">Active</div>
                        </div>
                    </div>

                    <!-- Total Ratings -->
                    <div class="tw_stat_card flex-fill" t-on-click="openAllRatings" style="cursor:pointer;">
                        <div class="tw_stat_icon bg-warning-subtle text-warning">
                            <i class="fa fa-star fa-2x"/>
                        </div>
                        <div class="tw_stat_body">
                            <div class="tw_stat_value"><t t-esc="state.stats.total_ratings || 0"/></div>
                            <div class="tw_stat_label">Total Ratings</div>
                        </div>
                    </div>

                    <!-- Rated Vendors -->
                    <div class="tw_stat_card flex-fill">
                        <div class="tw_stat_icon bg-info-subtle text-info">
                            <i class="fa fa-star-half-o fa-2x"/>
                        </div>
                        <div class="tw_stat_body">
                            <div class="tw_stat_value"><t t-esc="state.stats.rated_vendors || 0"/></div>
                            <div class="tw_stat_label">Rated Vendors</div>
                        </div>
                    </div>

                    <!-- Overall Average Rating -->
                    <div class="tw_stat_card flex-fill tw_stat_card_grand">
                        <div class="tw_stat_icon" style="background:rgba(245,166,35,.15);color:#F5A623;">
                            <i class="fa fa-trophy fa-2x"/>
                        </div>
                        <div class="tw_stat_body">
                            <div class="tw_stat_value">
                                <t t-esc="state.stats.overall_avg || '—'"/> / 5
                            </div>
                            <div class="tw_stat_label">
                                Overall Avg
                                <span class="d-block" style="color:#F5A623;letter-spacing:2px;font-size:0.85rem;">
                                    <t t-esc="overallStars"/>
                                </span>
                            </div>
                        </div>
                    </div>

                </div><!-- /stat row -->

                <!-- ── TRADE TYPE BREAKDOWN BADGES ───────────────── -->
                <t t-if="state.stats.type_counts and Object.keys(state.stats.type_counts).length > 0">
                    <div class="d-flex flex-wrap gap-2 px-4 pb-3">
                        <span class="fw-semibold small me-2 align-self-center tw_section_label">
                            By Trade Type:
                        </span>
                        <t t-foreach="Object.values(state.stats.type_counts || {})" t-as="tc" t-key="tc.label">
                            <span class="badge rounded-pill bg-primary px-3 py-2">
                                <t t-esc="tc.label"/>: <t t-esc="tc.count"/>
                            </span>
                        </t>
                    </div>
                </t>

                <!-- ── VENDOR SECTION HEADER ──────────────────────── -->
                <div class="px-4 pb-2 d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <h5 class="mb-0 fw-bold tw_section_title">
                        <i class="fa fa-handshake-o me-2 text-primary"/>
                        Vendor Rating Summary
                        <span class="badge bg-secondary rounded-pill ms-2 small">
                            <t t-esc="filteredVendors.length"/>
                        </span>
                    </h5>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <!-- Type filter -->
                        <select class="form-select form-select-sm" style="width:auto;"
                                t-model="state.filterType">
                            <option value="">All Types</option>
                            <t t-foreach="tradeTypeOptions" t-as="opt" t-key="opt.key">
                                <option t-att-value="opt.key">
                                    <t t-esc="opt.label"/>
                                </option>
                            </t>
                        </select>
                        <!-- Name search -->
                        <div style="position:relative;">
                            <i class="fa fa-search" style="position:absolute;left:8px;top:50%;transform:translateY(-50%);color:#adb5bd;"/>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   style="padding-left:28px;min-width:180px;background:#fff;color:#212529;border-color:#ced4da;"
                                   placeholder="Search vendors…"
                                   t-model="state.filterVendor"/>
                        </div>
                        <button t-attf-class="btn btn-sm p-0 {{ (state.filterVendor or state.filterType) ? '' : 'invisible' }}"
                                t-on-click="clearFilter" title="Clear filters">
                            <i class="fa fa-times-circle text-muted"/>
                        </button>
                    </div>
                </div>

                <!-- Totals bar -->
                <div class="tw_vendor_totals_bar px-4 pb-3 d-flex flex-wrap gap-3 align-items-center">
                    <span class="tw_totals_chip">
                        <i class="fa fa-building-o me-1"/>
                        <t t-esc="vendorTotals.count"/> vendor<t t-if="vendorTotals.count !== 1">s</t>
                        <t t-if="state.filterVendor or state.filterType">
                            of <t t-esc="state.vendors.length"/>
                        </t>
                    </span>
                    <span class="tw_totals_chip">
                        <i class="fa fa-star me-1" style="color:#F5A623;"/>
                        <t t-esc="vendorTotals.totalRatings"/> total rating<t t-if="vendorTotals.totalRatings !== 1">s</t>
                    </span>
                    <span class="tw_totals_chip tw_totals_value">
                        <i class="fa fa-trophy me-1"/>
                        Overall Avg: <strong><t t-esc="vendorTotals.overallAvg"/></strong> / 5
                        (<t t-esc="vendorTotals.ratedCount"/> rated)
                    </span>
                </div>

                <!-- Empty state -->
                <t t-if="filteredVendors.length === 0 and !state.loading">
                    <div class="text-center py-5 text-muted">
                        <i class="fa fa-info-circle fa-2x mb-2 d-block"/>
                        <t t-if="state.stats.total_vendors === 0">
                            No Tradeways vendors yet.<br/>
                            <small>Click <b>All Vendors</b> to add trade contacts.</small>
                        </t>
                        <t t-else="">No vendors match your filter.</t>
                    </div>
                </t>

                <!-- ── VENDOR CARDS GRID ──────────────────────────── -->
                <div class="tw_vendor_grid px-4 pb-4">
                    <t t-foreach="filteredVendors" t-as="vendor" t-key="vendor.id">
                        <div t-attf-class="tw_vendor_card {{ state.selectedVendor and state.selectedVendor.id === vendor.id ? 'tw_vendor_card_active' : '' }} {{ vendor.state === 'inactive' ? 'tw_vendor_card_inactive' : '' }}"
                             t-on-click="() => this.selectVendor(vendor)">

                            <!-- Card Header -->
                            <div class="tw_vendor_header">
                                <div t-attf-class="tw_vendor_avatar {{ state.selectedVendor and state.selectedVendor.id === vendor.id ? 'tw_vendor_avatar_active' : '' }}">
                                    <t t-if="state.selectedVendor and state.selectedVendor.id === vendor.id">
                                        <i class="fa fa-check"/>
                                    </t>
                                    <t t-else="">
                                        <t t-esc="(vendor.name || '?').charAt(0).toUpperCase()"/>
                                    </t>
                                </div>
                                <div class="tw_vendor_info">
                                    <div class="tw_vendor_name fw-bold">
                                        <t t-esc="vendor.name"/>
                                    </div>
                                    <div class="tw_vendor_email text-muted small">
                                        <t t-esc="vendor.email || vendor.contact_name || '—'"/>
                                    </div>
                                </div>
                                <div>
                                    <span t-attf-class="badge {{ tradeTypeBadgeClass(vendor.trade_type_key) }} rounded-pill">
                                        <t t-esc="vendor.trade_type"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Rating display -->
                            <div class="tw_vendor_rating_row">
                                <t t-if="vendor.avg_rating > 0">
                                    <span t-attf-class="tw_stars {{ ratingColorClass(vendor.avg_rating) }}">
                                        <t t-esc="ratingStars(vendor.avg_rating)"/>
                                    </span>
                                    <span class="fw-semibold ms-2" t-attf-class="{{ ratingColorClass(vendor.avg_rating) }}">
                                        <t t-esc="vendor.avg_rating.toFixed(1)"/> / 5
                                    </span>
                                    <span class="text-muted small ms-2">
                                        (<t t-esc="vendor.rating_count"/> rating<t t-if="vendor.rating_count !== 1">s</t>)
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted small fst-italic">
                                        <i class="fa fa-star-o me-1"/>Not yet rated
                                    </span>
                                </t>
                            </div>

                            <!-- Latest comment preview -->
                            <t t-if="vendor.recent_comment">
                                <div class="tw_vendor_comment_preview">
                                    <i class="fa fa-comment-o me-1 text-muted"/>
                                    <span class="text-muted small fst-italic">
                                        "<t t-esc="vendor.recent_comment.substring(0, 80)"/>
                                        <t t-if="vendor.recent_comment.length > 80">…</t>"
                                    </span>
                                </div>
                            </t>

                            <!-- Card footer -->
                            <div class="tw_vendor_footer_row d-flex justify-content-between align-items-center mt-2">
                                <span t-attf-class="badge {{ vendor.state === 'active' ? 'bg-success' : 'bg-secondary' }} rounded-pill">
                                    <t t-esc="vendor.state"/>
                                </span>
                                <button class="btn btn-sm btn-outline-primary tw_view_btn"
                                        t-on-click.stop="() => this.openVendorForm(vendor.id)"
                                        title="Open vendor record">
                                    <i class="fa fa-external-link me-1"/>Open
                                </button>
                            </div>

                        </div>
                    </t>
                </div><!-- /tw_vendor_grid -->

                <!-- ╔══════════════════════════════════════════════════════╗
                     ║  VENDOR DETAIL NOTEBOOK                              ║
                     ╚══════════════════════════════════════════════════════╝ -->
                <t t-if="state.selectedVendor">
                    <div class="tw_vendor_notebook card mx-4 mb-4 shadow-sm" t-ref="notebook"
                         style="color-scheme:light;background:#fff;color:#212529;">

                        <!-- Notebook Header Tabs -->
                        <div class="card-header d-flex align-items-center justify-content-between p-0 ps-3">
                            <ul class="nav nav-tabs border-0" role="tablist">
                                <li class="nav-item">
                                    <a t-attf-class="nav-link {{ state.activeTab === 'history' ? 'active fw-semibold' : 'text-muted' }}"
                                       href="#" t-on-click.prevent="() => this.setActiveTab('history')">
                                        <i class="fa fa-history me-1"/>Rating History
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a t-attf-class="nav-link {{ state.activeTab === 'details' ? 'active fw-semibold' : 'text-muted' }}"
                                       href="#" t-on-click.prevent="() => this.setActiveTab('details')">
                                        <i class="fa fa-info-circle me-1"/>Details
                                    </a>
                                </li>
                            </ul>
                            <div class="d-flex align-items-center gap-2 pe-3">
                                <button class="btn btn-sm btn-primary"
                                        t-on-click="() => this.openVendorForm(state.selectedVendor.id)">
                                    <i class="fa fa-external-link me-1"/>Open Vendor
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        t-on-click="closeNotebook">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </div>

                        <!-- Vendor Title Bar -->
                        <div class="d-flex align-items-center gap-3 px-4 py-2 bg-light border-bottom">
                            <div class="tw_vendor_avatar" style="width:40px;height:40px;font-size:1.2rem;">
                                <t t-esc="(state.selectedVendor.name || '?').charAt(0).toUpperCase()"/>
                            </div>
                            <div>
                                <div class="fw-bold fs-6"><t t-esc="state.selectedVendor.name"/></div>
                                <div class="text-muted small">
                                    <t t-esc="state.selectedVendor.trade_type"/>
                                </div>
                            </div>
                            <!-- Overall rating badge -->
                            <div class="ms-auto d-flex align-items-center gap-2">
                                <t t-if="state.selectedVendor.avg_rating > 0">
                                    <span t-attf-class="tw_stars_lg {{ ratingColorClass(state.selectedVendor.avg_rating) }}">
                                        <t t-esc="ratingStars(state.selectedVendor.avg_rating)"/>
                                    </span>
                                    <span class="fw-bold" t-attf-class="{{ ratingColorClass(state.selectedVendor.avg_rating) }}">
                                        <t t-esc="state.selectedVendor.avg_rating.toFixed(2)"/> / 5
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted fst-italic small">Not yet rated</span>
                                </t>
                            </div>
                        </div>

                        <!-- Tab Content -->
                        <div class="card-body p-4">

                            <!-- ── Rating History Tab ──────────────── -->
                            <t t-if="state.activeTab === 'history'">

                                <!-- Loading spinner -->
                                <t t-if="state.ratingHistoryLoading">
                                    <div class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary me-2"/>
                                        <span class="text-muted">Loading rating history…</span>
                                    </div>
                                </t>

                                <!-- Rating history table -->
                                <t t-elif="state.ratingHistory.length > 0">
                                    <div class="tw_summary_table_wrap">
                                        <table class="tw_summary_table w-100">
                                            <thead>
                                                <tr>
                                                    <th>Stars</th>
                                                    <th>Rating</th>
                                                    <th>Comment</th>
                                                    <th>Rated By</th>
                                                    <th>Date</th>
                                                    <th>PO</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="state.ratingHistory" t-as="r" t-key="r.id">
                                                    <tr>
                                                        <td style="font-size:1.1rem;color:#F5A623;letter-spacing:1px;">
                                                            <t t-esc="r.stars"/>
                                                        </td>
                                                        <td class="fw-semibold">
                                                            <t t-esc="r.rating"/> / 5
                                                        </td>
                                                        <td class="text-muted">
                                                            <t t-esc="r.comment || '—'"/>
                                                        </td>
                                                        <td>
                                                            <i class="fa fa-user-o me-1 text-muted"/>
                                                            <t t-esc="r.rated_by"/>
                                                        </td>
                                                        <td class="text-muted small">
                                                            <t t-esc="r.rating_date"/>
                                                        </td>
                                                        <td class="text-muted small">
                                                            <t t-esc="r.po_name"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>

                                <t t-else="">
                                    <div class="text-center py-4 text-muted">
                                        <i class="fa fa-star-o fa-2x mb-2 d-block"/>
                                        No ratings submitted yet for this vendor.
                                    </div>
                                </t>

                            </t>

                            <!-- ── Details Tab ─────────────────────── -->
                            <t t-elif="state.activeTab === 'details'">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="border rounded p-3">
                                            <div class="text-muted small mb-2">
                                                <i class="fa fa-user me-1"/>Contact
                                            </div>
                                            <div><strong><t t-esc="state.selectedVendor.contact_name || '—'"/></strong></div>
                                            <div class="text-muted small mt-1">
                                                <t t-if="state.selectedVendor.phone">
                                                    <i class="fa fa-phone me-1"/>
                                                    <t t-esc="state.selectedVendor.phone"/>
                                                </t>
                                            </div>
                                            <div class="text-muted small">
                                                <t t-if="state.selectedVendor.email">
                                                    <i class="fa fa-envelope me-1"/>
                                                    <t t-esc="state.selectedVendor.email"/>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3">
                                            <div class="text-muted small mb-2">
                                                <i class="fa fa-tag me-1"/>Trade Info
                                            </div>
                                            <div>Type: <strong><t t-esc="state.selectedVendor.trade_type"/></strong></div>
                                            <div>Status:
                                                <span t-attf-class="badge {{ state.selectedVendor.state === 'active' ? 'bg-success' : 'bg-secondary' }} ms-1">
                                                    <t t-esc="state.selectedVendor.state"/>
                                                </span>
                                            </div>
                                            <div class="mt-2">
                                                Ratings given: <strong><t t-esc="state.selectedVendor.rating_count"/></strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>

                        </div><!-- /card-body -->
                    </div><!-- /tw_vendor_notebook -->
                </t><!-- /t-if selectedVendor -->

            </div><!-- /tw_dash_scroll -->

        </t><!-- /main dashboard -->
    </div><!-- /tw_dashboard -->
</t>

</templates>
