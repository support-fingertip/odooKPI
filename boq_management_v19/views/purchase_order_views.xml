<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Task 3 — RFQ inside BOQ
        Inherit the standard purchase.order form to:
        1. Show BOQ Reference smart button (opens linked BOQ record)
        2. Show BOQ Reference field in main group
        3. Make Description field visible in order lines
        Note: Odoo 19 renders the totals footer via the `tax_totals` widget
        which already includes a "Total Tax" row natively — no extra xpath needed.
    -->

    <!-- ═══════════════════════════════════════════════════════════════════
         PURCHASE ORDER FORM — Inherit for BOQ fields
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_purchase_order_form_boq_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.boq.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- ── 1. BOQ smart button in button_box ────────────────────── -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_boq"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-calculator"
                        invisible="not boq_id"
                        string="View BOQ">
                    <field name="boq_id" widget="statinfo" string="BOQ"/>
                </button>
            </xpath>

            <!-- ── 2. BOQ Reference field below partner ─────────────────── -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="boq_id"
                       string="BOQ Reference"
                       options="{'no_create': True}"
                       invisible="not boq_id"/>
            </xpath>

            <!-- ── 3. Make Description (name) visible in order lines ──────── -->
            <!--
                In the standard Odoo 19 purchase form the `name` column on
                order lines may be optional/hidden.  Force optional="show" so
                users always see the description without toggling columns.
            -->
            <xpath expr="//field[@name='order_line']//field[@name='name']"
                   position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>

            <!--
                Total Tax in footer:
                Odoo 19 renders purchase totals via the `tax_totals` widget
                which already includes a "Total Tax" row automatically.
                No additional xpath is required — the row is present by default.
            -->

        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         PURCHASE RFQ LIST — Inherit to show BOQ column
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_purchase_rfq_list_boq_inherit" model="ir.ui.view">
        <field name="name">purchase.order.rfq.list.boq.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_rfq"/>
        <field name="arch" type="xml">
            <!--
                Append BOQ Ref column to the end of the RFQ list.
                Targets <list> directly — robust regardless of which other
                columns exist in the Odoo 19 purchase_rfq list view.
            -->
            <xpath expr="//list" position="inside">
                <field name="boq_id" string="BOQ Ref" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         BOQ-SPECIFIC RFQ ACTION — filtered to RFQs linked to any BOQ
         Placed in BOQ → Reporting menu (sequence 10)
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="action_boq_rfq_list" model="ir.actions.act_window">
        <field name="name">RFQs from BOQ</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('boq_id', '!=', False)]</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No RFQs linked to a BOQ yet!
            </p>
            <p>
                Open a BOQ record, assign vendors to line items, then click
                <b>Create RFQ</b> to generate purchase quotations linked
                to the BOQ automatically.
            </p>
        </field>
    </record>

</odoo>
