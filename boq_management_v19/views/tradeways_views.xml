<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         TRADEWAYS VENDOR — Views (Task 4)
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- ── Tradeways Vendor Form View ──────────────────────────────────── -->
    <record id="view_tradeways_vendor_form" model="ir.ui.view">
        <field name="name">tradeways.vendor.form</field>
        <field name="model">tradeways.vendor</field>
        <field name="arch" type="xml">
            <form string="Tradeways Vendor">
                <header>
                    <button name="action_open_add_rating" type="object"
                            string="Add Rating"
                            class="btn btn-primary"
                            groups="boq_management_v19.group_boq_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_vendor_ratings_tw"
                                class="oe_stat_button" icon="fa-star"
                                invisible="rating_count == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="avg_rating" widget="float" digits="[3,1]"/> / 5
                                </span>
                                <span class="o_stat_text">
                                    Avg Rating (<field name="rating_count"/> given)
                                </span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Company / Trade Name…"/>
                        </h1>
                        <h3>
                            <field name="trade_type"/>
                        </h3>
                    </div>

                    <!-- Overall rating display (Task 4) -->
                    <div invisible="avg_rating == 0"
                         style="background: #fff8e1; border: 1px solid #ffe082; border-radius: 8px;
                                padding: 12px 20px; margin-bottom: 16px; display: flex; align-items: center; gap: 16px;">
                        <i class="fa fa-star fa-2x" style="color: #F5A623;"/>
                        <div>
                            <div style="font-size: 1.5rem; font-weight: 700; color: #875A7B;">
                                <field name="avg_rating" widget="float" digits="[3,2]" readonly="1"/>
                                <span style="font-size: 1rem; color: #6c757d;"> / 5 stars</span>
                            </div>
                            <div style="font-size: 0.9rem; color: #6c757d;">
                                Based on <field name="rating_count" readonly="1"/> rating(s)
                            </div>
                        </div>
                    </div>

                    <group>
                        <group string="Contact Details">
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="contact_name"/>
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="website" widget="url"/>
                        </group>
                        <group string="Details">
                            <field name="trade_type"/>
                            <field name="state"/>
                            <field name="address"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Ratings Tab -->
                        <page string="Ratings" name="ratings">
                            <field name="rating_ids" mode="list"
                                   context="{'default_tradeways_id': active_id}">
                                <list string="Ratings" editable="bottom"
                                      groups="boq_management_v19.group_boq_manager">
                                    <field name="rating" widget="priority"/>
                                    <field name="rating_display" string="Stars" readonly="1"/>
                                    <field name="comment" string="Comment"/>
                                    <field name="rated_by" string="Rated By" readonly="1"/>
                                    <field name="rating_date" string="Date"/>
                                    <field name="purchase_order_id" string="PO" optional="show"/>
                                </list>
                                <list string="Ratings (read-only)"
                                      groups="!boq_management_v19.group_boq_manager">
                                    <field name="rating_display" string="Stars" readonly="1"/>
                                    <field name="comment" string="Comment" readonly="1"/>
                                    <field name="rated_by" string="Rated By" readonly="1"/>
                                    <field name="rating_date" string="Date" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <!-- Notes Tab -->
                        <page string="Notes" name="notes">
                            <field name="notes" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ── Tradeways Vendor List View ──────────────────────────────────── -->
    <record id="view_tradeways_vendor_list" model="ir.ui.view">
        <field name="name">tradeways.vendor.list</field>
        <field name="model">tradeways.vendor</field>
        <field name="arch" type="xml">
            <list string="Tradeways Vendors" decoration-muted="state == 'inactive'">
                <field name="name"/>
                <field name="trade_type"/>
                <field name="contact_name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="avg_rating" string="Avg Rating" optional="show"/>
                <field name="rating_count" string="# Ratings" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <!-- ── Tradeways Vendor Kanban View ──────────────────────────────── -->
    <record id="view_tradeways_vendor_kanban" model="ir.ui.view">
        <field name="name">tradeways.vendor.kanban</field>
        <field name="model">tradeways.vendor</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="trade_type"/>
                <field name="avg_rating"/>
                <field name="rating_count"/>
                <field name="state"/>
                <field name="email"/>
                <field name="phone"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex flex-column gap-1 p-1">
                            <div class="d-flex align-items-center justify-content-between">
                                <strong class="fs-6">
                                    <field name="name"/>
                                </strong>
                                <span t-attf-class="badge {{ record.state.raw_value == 'active' ? 'bg-success' : 'bg-secondary' }}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="text-muted small">
                                <i class="fa fa-tag me-1"/>
                                <field name="trade_type"/>
                            </div>
                            <div t-if="record.avg_rating.raw_value > 0"
                                 style="color: #F5A623; font-size: 1.1rem;">
                                <i class="fa fa-star"/>
                                <field name="avg_rating" widget="float" digits="[3,1]"/> / 5
                                <span class="text-muted small">
                                    (<field name="rating_count"/> ratings)
                                </span>
                            </div>
                            <div t-else="" class="text-muted small fst-italic">
                                Not yet rated
                            </div>
                            <div t-if="record.email.raw_value" class="text-muted small">
                                <i class="fa fa-envelope me-1"/>
                                <field name="email"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Tradeways Vendor Search View ──────────────────────────────── -->
    <record id="view_tradeways_vendor_search" model="ir.ui.view">
        <field name="name">tradeways.vendor.search</field>
        <field name="model">tradeways.vendor</field>
        <field name="arch" type="xml">
            <search string="Search Tradeways Vendors">
                <field name="name" string="Name"/>
                <field name="contact_name" string="Contact"/>
                <field name="email" string="Email"/>
                <filter name="active" string="Active" domain="[('state','=','active')]"/>
                <filter name="inactive" string="Inactive" domain="[('state','=','inactive')]"/>
                <separator/>
                <filter name="rated" string="Rated" domain="[('rating_count','>',0)]"/>
                <filter name="unrated" string="Not Rated" domain="[('rating_count','=',0)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_trade_type" string="Trade Type"
                            context="{'group_by': 'trade_type'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Tradeways Rating Form View ───────────────────────────────── -->
    <record id="view_tradeways_rating_form" model="ir.ui.view">
        <field name="name">tradeways.rating.form</field>
        <field name="model">tradeways.rating</field>
        <field name="arch" type="xml">
            <form string="Tradeways Rating">
                <sheet>
                    <group>
                        <group>
                            <field name="tradeways_id" options="{'no_create': True}"/>
                            <field name="rating" widget="priority"/>
                            <field name="rating_display" string="Stars" readonly="1"/>
                            <field name="rating_date"/>
                        </group>
                        <group>
                            <field name="rated_by" readonly="1"/>
                            <field name="purchase_order_id"
                                   options="{'no_create': True}"
                                   string="Related PO (optional)"/>
                        </group>
                    </group>
                    <group string="Comment">
                        <field name="comment" nolabel="1"
                               placeholder="Add performance remarks…"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Tradeways Rating List View ───────────────────────────────── -->
    <record id="view_tradeways_rating_list" model="ir.ui.view">
        <field name="name">tradeways.rating.list</field>
        <field name="model">tradeways.rating</field>
        <field name="arch" type="xml">
            <list string="Ratings" default_order="rating_date desc">
                <field name="tradeways_id" string="Vendor"/>
                <field name="rating" widget="priority"/>
                <field name="rating_display" string="Stars" readonly="1"/>
                <field name="comment" string="Comment" optional="show"/>
                <field name="rated_by" string="Rated By" readonly="1"/>
                <field name="rating_date" string="Date"/>
                <field name="purchase_order_id" string="PO" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ── Actions ──────────────────────────────────────────────────── -->

    <record id="action_tradeways_vendor" model="ir.actions.act_window">
        <field name="name">Tradeways Vendors</field>
        <field name="res_model">tradeways.vendor</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Tradeways vendors yet!
            </p>
            <p>
                Add your trade contacts (subcontractors, suppliers, consultants)
                and rate their performance after each engagement.
            </p>
        </field>
    </record>

    <record id="action_tradeways_rating" model="ir.actions.act_window">
        <field name="name">Tradeways Ratings</field>
        <field name="res_model">tradeways.rating</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No ratings submitted yet!</p>
            <p>Open a Tradeways vendor and click <b>Add Rating</b>.</p>
        </field>
    </record>

    <!-- Quick-create rating action (used from vendor form button) -->
    <record id="action_tradeways_rating_new" model="ir.actions.act_window">
        <field name="name">Add Tradeways Rating</field>
        <field name="res_model">tradeways.rating</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_tradeways_id': active_id}</field>
    </record>

    <!-- Tradeways Dashboard client action -->
    <record id="action_tradeways_dashboard" model="ir.actions.client">
        <field name="name">Tradeways Dashboard</field>
        <field name="tag">boq_management_v19.tradeways_dashboard_action</field>
    </record>

</odoo>
