              groups="boq_management_v19.group_boq_manager"/>

    <!-- ── Reporting section ─────────────────────────────────────────── -->
    <menuitem id="menu_boq_report"
              name="Reporting"
              parent="menu_boq_root"
              sequence="50"
              groups="boq_management_v19.group_boq_manager"/>

    <menuitem id="menu_boq_rfq_list"
