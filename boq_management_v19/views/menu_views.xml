              parent="menu_boq_report"
              action="action_boq_vendor_list"
              sequence="20"
              groups="boq_management_v19.group_boq_manager"/>

    <!-- ── Configuration section ─────────────────────────────────────── -->
    <menuitem id="menu_boq_config"
              name="Configuration"
              parent="menu_boq_root"
              sequence="90"
              groups="boq_management_v19.group_boq_manager"/>

    <menuitem id="menu_boq_categories"
              name="Work Categories"
              parent="menu_boq_config"
              action="action_boq_category"
              sequence="10"/>

