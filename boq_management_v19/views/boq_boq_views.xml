                                       domain="[('type_tax_use','in',('purchase','all'))]"
                                       optional="show"/>
                                <field name="subtotal" string="Subtotal"
                                       readonly="1" sum="Tab Subtotal"/>
                                <field name="tax_amount" string="Tax Amt"
                                       readonly="1" optional="show"/>
                                <field name="total_value" string="Total (incl. Tax)"
                                       readonly="1" sum="Tab Total"/>
                                <field name="margin_percent" string="Margin %"
