<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ═══════════════════════════════════════════════════════════════════════
     BOQ — MAIN FORM VIEW (Odoo 19 Enterprise)
═══════════════════════════════════════════════════════════════════════ -->
<record id="view_boq_boq_form" model="ir.ui.view">
    <field name="name">boq.boq.form</field>
    <field name="model">boq.boq</field>
    <field name="arch" type="xml">
        <form string="Bill of Quantities" class="boq_enterprise_form">

            <!-- ── HEADER ──────────────────────────────────────────── -->
            <header>
                <button name="action_submit"   string="Submit"        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
                <button name="action_approve"  string="Approve"       type="object"
                        class="btn-primary"
                        groups="boq_management_v19.group_boq_manager"
                        invisible="state != 'submitted'"/>
                <button name="action_reject"   string="Reject"        type="object"
                        class="btn-secondary"
                        groups="boq_management_v19.group_boq_manager"
                        invisible="state not in ('submitted',)"/>
                <button name="action_done"     string="Mark Done"     type="object"
                        class="btn-primary"
                        invisible="state != 'approved'"/>
                <button name="action_reset_draft" string="Reset to Draft" type="object"
                        class="btn-secondary"
                        invisible="state not in ('rejected', 'submitted')"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="draft,submitted,approved,done"/>
            </header>

            <sheet>
                <!-- ── SMART BUTTONS ──────────────────────────────── -->
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-ul">
                        <field name="line_count" widget="statinfo" string="Lines"/>
                    </button>
                    <button name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="total_amount" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Total</span>
                        </div>
                    </button>
                </div>

                <!-- ── PRIORITY STAR ──────────────────────────────── -->
                <field name="priority" widget="priority" class="float-start me-3 mt-1"/>

                <!-- ── TITLE AREA ─────────────────────────────────── -->
                <div class="oe_title">
                    <label for="name" string="BOQ Reference"/>
                    <h1 class="boq_ref_number">
                        <field name="name" readonly="1"/>
                    </h1>
                    <div class="boq_project_title" invisible="not project_name">
                        <i class="fa fa-briefcase me-1 text-muted"/>
                        <field name="project_name" class="boq_project_inline"
                               placeholder="Project Name"/>
                    </div>
                </div>

                <!-- ── HERO CARD: customer + project ─────────────── -->
                <div class="boq_hero_card">
                    <div class="boq_hero_left">
                        <div class="boq_hero_icon">
                            <i class="fa fa-calculator fa-2x"/>
                        </div>
                        <div class="boq_hero_info">
                            <div class="boq_field_row">
                                <label for="partner_id" class="boq_field_label"/>
                                <field name="partner_id"
                                       widget="many2one"
                                       options="{'no_create_edit': True}"
                                       placeholder="Select customer…"/>
                            </div>
                            <div class="boq_field_row">
                                <label for="project_name" class="boq_field_label"/>
                                <field name="project_name" placeholder="Project / Contract"/>
                            </div>
                            <div class="boq_field_row">
                                <label for="project_location" class="boq_field_label"/>
                                <field name="project_location" placeholder="Site address"/>
                            </div>
                        </div>
                    </div>
                    <div class="boq_hero_right">
                        <div class="boq_field_row">
                            <label for="user_id" class="boq_field_label"/>
                            <field name="user_id"
                                   widget="many2one_avatar_user"
                                   options="{'no_create_edit': True}"/>
                        </div>
                        <div class="boq_field_row">
                            <label for="date" class="boq_field_label"/>
                            <field name="date"/>
                        </div>
                        <div class="boq_field_row">
                            <label for="validity_date" class="boq_field_label"/>
                            <field name="validity_date"/>
                        </div>
                        <div class="boq_field_row" groups="base.group_multi_company">
                            <label for="company_id" class="boq_field_label"/>
                            <field name="company_id" options="{'no_create': True}"/>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════
                     CATEGORY SELECTOR — the control for tab visibility
                     Selecting tags here shows/hides the notebook tabs.
                ═══════════════════════════════════════════════════ -->
                <div class="boq_category_panel">
                    <div class="boq_category_panel_header">
                        <span class="boq_panel_title">
                            <i class="fa fa-tags me-2"/>
                            Work Categories
                        </span>
                        <span class="boq_panel_hint text-muted">
                            Select categories to activate their tabs below
                        </span>
                    </div>
                    <div class="boq_category_panel_body">
                        <field name="category_ids"
                               widget="many2many_tags"
                               options="{'color_field': 'color', 'no_create_edit': True}"
                               placeholder="Click to add work categories…"
                               class="boq_category_tags"/>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════
                     LIVE SUMMARY STRIP — per-category totals
                ═══════════════════════════════════════════════════ -->
                <div class="boq_summary_strip">
                    <div class="boq_summary_item boq_cat_electrical"
                         invisible="not show_electrical">
                        <i class="fa fa-bolt boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">Electrical</span>
                            <field name="electrical_total" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_summary_value"/>
                        </div>
                    </div>
                    <div class="boq_summary_item boq_cat_civil"
                         invisible="not show_civil">
                        <i class="fa fa-building boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">Civil</span>
                            <field name="civil_total" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_summary_value"/>
                        </div>
                    </div>
                    <div class="boq_summary_item boq_cat_lighting"
                         invisible="not show_lighting">
                        <i class="fa fa-lightbulb-o boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">Lighting</span>
                            <field name="lighting_total" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_summary_value"/>
                        </div>
                    </div>
                    <div class="boq_summary_item boq_cat_plumbing"
                         invisible="not show_plumbing">
                        <i class="fa fa-tint boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">Plumbing</span>
                            <field name="plumbing_total" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_summary_value"/>
                        </div>
                    </div>
                    <div class="boq_summary_item boq_cat_hvac"
                         invisible="not show_hvac">
                        <i class="fa fa-snowflake-o boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">HVAC</span>
                            <field name="hvac_total" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_summary_value"/>
                        </div>
                    </div>
                    <div class="boq_summary_item boq_cat_finishing"
                         invisible="not show_finishing">
                        <i class="fa fa-paint-brush boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">Finishing</span>
                            <field name="finishing_total" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_summary_value"/>
                        </div>
                    </div>
                    <!-- Grand total always visible -->
                    <div class="boq_summary_item boq_grand_pill">
                        <i class="fa fa-sigma boq_summary_icon"/>
                        <div class="boq_summary_data">
                            <span class="boq_summary_label">Grand Total</span>
                            <field name="total_amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1" nolabel="1"
                                   class="boq_grand_total_value"/>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════
                     NOTEBOOK — one tab per category
                     Tab is hidden when its boolean flag is False.
                ═══════════════════════════════════════════════════ -->
                <notebook class="boq_notebook_enterprise">

                    <!-- ──────────────────── ELECTRICAL ─────────── -->
                    <page string="⚡ Electrical" name="tab_electrical"
                          invisible="not show_electrical">
                        <div class="boq_tab_band boq_band_electrical">
                            <div class="boq_band_left">
                                <i class="fa fa-bolt fa-lg me-2"/>
                                <span class="boq_band_title">Electrical Works</span>
                            </div>
                            <div class="boq_band_right">
                                <span class="boq_band_total_label">Tab Total</span>
                                <field name="electrical_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"
                                       class="boq_band_total_value"/>
                            </div>
                        </div>
                        <field name="electrical_line_ids"
                               context="{'default_category_id': electrical_category_id}"
                               mode="list">
                            <list editable="bottom" class="boq_line_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" required="1"
                                       options="{'no_create_edit': False}"/>
                                <field name="product_name"/>
                                <field name="product_type"/>
                                <field name="qty"/>
                                <field name="uom_id" readonly="1" optional="show"/>
                                <field name="unit_price"/>
                                <field name="discount" optional="hide"/>
                                <field name="subtotal" readonly="1" sum="Subtotal"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" optional="hide"/>
                                <field name="category_id" column_invisible="True" required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ──────────────────── CIVIL ───────────────── -->
                    <page string="🏗️ Civil" name="tab_civil"
                          invisible="not show_civil">
                        <div class="boq_tab_band boq_band_civil">
                            <div class="boq_band_left">
                                <i class="fa fa-building fa-lg me-2"/>
                                <span class="boq_band_title">Civil Works</span>
                            </div>
                            <div class="boq_band_right">
                                <span class="boq_band_total_label">Tab Total</span>
                                <field name="civil_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"
                                       class="boq_band_total_value"/>
                            </div>
                        </div>
                        <field name="civil_line_ids"
                               context="{'default_category_id': civil_category_id}"
                               mode="list">
                            <list editable="bottom" class="boq_line_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" required="1"/>
                                <field name="product_name"/>
                                <field name="product_type"/>
                                <field name="qty"/>
                                <field name="uom_id" readonly="1" optional="show"/>
                                <field name="unit_price"/>
                                <field name="discount" optional="hide"/>
                                <field name="subtotal" readonly="1" sum="Subtotal"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" optional="hide"/>
                                <field name="category_id" column_invisible="True" required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ──────────────────── LIGHTING ────────────── -->
                    <page string="💡 Lighting" name="tab_lighting"
                          invisible="not show_lighting">
                        <div class="boq_tab_band boq_band_lighting">
                            <div class="boq_band_left">
                                <i class="fa fa-lightbulb-o fa-lg me-2"/>
                                <span class="boq_band_title">Lighting Works</span>
                            </div>
                            <div class="boq_band_right">
                                <span class="boq_band_total_label">Tab Total</span>
                                <field name="lighting_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"
                                       class="boq_band_total_value"/>
                            </div>
                        </div>
                        <field name="lighting_line_ids"
                               context="{'default_category_id': lighting_category_id}"
                               mode="list">
                            <list editable="bottom" class="boq_line_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" required="1"/>
                                <field name="product_name"/>
                                <field name="product_type"/>
                                <field name="qty"/>
                                <field name="uom_id" readonly="1" optional="show"/>
                                <field name="unit_price"/>
                                <field name="discount" optional="hide"/>
                                <field name="subtotal" readonly="1" sum="Subtotal"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" optional="hide"/>
                                <field name="category_id" column_invisible="True" required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ──────────────────── PLUMBING ────────────── -->
                    <page string="🔧 Plumbing" name="tab_plumbing"
                          invisible="not show_plumbing">
                        <div class="boq_tab_band boq_band_plumbing">
                            <div class="boq_band_left">
                                <i class="fa fa-tint fa-lg me-2"/>
                                <span class="boq_band_title">Plumbing Works</span>
                            </div>
                            <div class="boq_band_right">
                                <span class="boq_band_total_label">Tab Total</span>
                                <field name="plumbing_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"
                                       class="boq_band_total_value"/>
                            </div>
                        </div>
                        <field name="plumbing_line_ids"
                               context="{'default_category_id': plumbing_category_id}"
                               mode="list">
                            <list editable="bottom" class="boq_line_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" required="1"/>
                                <field name="product_name"/>
                                <field name="product_type"/>
                                <field name="qty"/>
                                <field name="uom_id" readonly="1" optional="show"/>
                                <field name="unit_price"/>
                                <field name="discount" optional="hide"/>
                                <field name="subtotal" readonly="1" sum="Subtotal"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" optional="hide"/>
                                <field name="category_id" column_invisible="True" required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ──────────────────── HVAC ─────────────────── -->
                    <page string="❄️ HVAC" name="tab_hvac"
                          invisible="not show_hvac">
                        <div class="boq_tab_band boq_band_hvac">
                            <div class="boq_band_left">
                                <i class="fa fa-snowflake-o fa-lg me-2"/>
                                <span class="boq_band_title">HVAC Works</span>
                            </div>
                            <div class="boq_band_right">
                                <span class="boq_band_total_label">Tab Total</span>
                                <field name="hvac_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"
                                       class="boq_band_total_value"/>
                            </div>
                        </div>
                        <field name="hvac_line_ids"
                               context="{'default_category_id': hvac_category_id}"
                               mode="list">
                            <list editable="bottom" class="boq_line_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" required="1"/>
                                <field name="product_name"/>
                                <field name="product_type"/>
                                <field name="qty"/>
                                <field name="uom_id" readonly="1" optional="show"/>
                                <field name="unit_price"/>
                                <field name="discount" optional="hide"/>
                                <field name="subtotal" readonly="1" sum="Subtotal"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" optional="hide"/>
                                <field name="category_id" column_invisible="True" required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ──────────────────── FINISHING ───────────── -->
                    <page string="🎨 Finishing" name="tab_finishing"
                          invisible="not show_finishing">
                        <div class="boq_tab_band boq_band_finishing">
                            <div class="boq_band_left">
                                <i class="fa fa-paint-brush fa-lg me-2"/>
                                <span class="boq_band_title">Finishing Works</span>
                            </div>
                            <div class="boq_band_right">
                                <span class="boq_band_total_label">Tab Total</span>
                                <field name="finishing_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"
                                       class="boq_band_total_value"/>
                            </div>
                        </div>
                        <field name="finishing_line_ids"
                               context="{'default_category_id': finishing_category_id}"
                               mode="list">
                            <list editable="bottom" class="boq_line_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" required="1"/>
                                <field name="product_name"/>
                                <field name="product_type"/>
                                <field name="qty"/>
                                <field name="uom_id" readonly="1" optional="show"/>
                                <field name="unit_price"/>
                                <field name="discount" optional="hide"/>
                                <field name="subtotal" readonly="1" sum="Subtotal"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" optional="hide"/>
                                <field name="category_id" column_invisible="True" required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ──────────────────── NOTES / TERMS ────────── -->
                    <page string="📋 Terms &amp; Notes" name="tab_notes">
                        <field name="notes"
                               placeholder="Enter terms, conditions, special notes…"/>
                    </page>

                </notebook>

                <!-- ── hidden fields needed by widgets ──────────── -->
                <field name="currency_id" invisible="1"/>
                <field name="show_electrical" invisible="1"/>
                <field name="show_civil"      invisible="1"/>
                <field name="show_lighting"   invisible="1"/>
                <field name="show_plumbing"   invisible="1"/>
                <field name="show_hvac"       invisible="1"/>
                <field name="show_finishing"  invisible="1"/>

            </sheet>

            <chatter/>

        </form>
    </field>
</record>

<!-- ═══════════════════════════════════════════════════════════════════════
     BOQ — LIST VIEW
═══════════════════════════════════════════════════════════════════════ -->
<record id="view_boq_boq_list" model="ir.ui.view">
    <field name="name">boq.boq.list</field>
    <field name="model">boq.boq</field>
    <field name="arch" type="xml">
        <list string="Bills of Quantities"
              decoration-success="state == 'done'"
              decoration-info="state == 'approved'"
              decoration-warning="state == 'submitted'"
              decoration-muted="state in ('rejected',)">
            <field name="priority" widget="priority" nolabel="1" optional="show"/>
            <field name="name"/>
            <field name="partner_id"/>
            <field name="project_name" optional="show"/>
            <field name="user_id" widget="many2one_avatar_user" optional="show"/>
            <field name="date"/>
            <field name="validity_date" optional="hide"/>
            <field name="category_ids" widget="many2many_tags"
                   options="{'color_field': 'color'}"/>
            <field name="line_count" string="Lines" optional="show"/>
            <field name="total_amount" widget="monetary"
                   options="{'currency_field': 'currency_id'}"
                   sum="Grand Total"/>
            <field name="currency_id" column_invisible="True"/>
            <field name="state" widget="badge"
                   decoration-success="state == 'done'"
                   decoration-info="state == 'approved'"
                   decoration-warning="state == 'submitted'"
                   decoration-primary="state == 'draft'"
                   decoration-danger="state == 'rejected'"/>
        </list>
    </field>
</record>

<!-- ═══════════════════════════════════════════════════════════════════════
     BOQ — KANBAN VIEW (Enterprise)
═══════════════════════════════════════════════════════════════════════ -->
<record id="view_boq_boq_kanban" model="ir.ui.view">
    <field name="name">boq.boq.kanban</field>
    <field name="model">boq.boq</field>
    <field name="arch" type="xml">
        <kanban class="boq_kanban_view"
                default_group_by="state"
                quick_create="false"
                group_create="false">
            <field name="name"/>
            <field name="partner_id"/>
            <field name="project_name"/>
            <field name="user_id"/>
            <field name="date"/>
            <field name="state"/>
            <field name="priority"/>
            <field name="total_amount"/>
            <field name="currency_id"/>
            <field name="category_ids"/>
            <field name="line_count"/>
            <templates>
                <t t-name="card" class="boq_kanban_card">

                    <!-- Card header with gradient -->
                    <div class="boq_kcard_header">
                        <div class="boq_kcard_ref">
                            <field name="priority" widget="priority"/>
                            <span class="boq_kcard_name fw-bold ms-1">
                                <field name="name"/>
                            </span>
                        </div>
                        <field name="state" widget="label_selection"
                               options="{'classes': {
                                   'draft':     'secondary',
                                   'submitted': 'warning',
                                   'approved':  'info',
                                   'rejected':  'danger',
                                   'done':      'success'
                               }}"/>
                    </div>

                    <!-- Card body -->
                    <div class="boq_kcard_body">
                        <div class="boq_kcard_row">
                            <i class="fa fa-user-o text-muted me-2"/>
                            <field name="partner_id"/>
                        </div>
                        <div class="boq_kcard_row" invisible="not project_name">
                            <i class="fa fa-briefcase text-muted me-2"/>
                            <field name="project_name"/>
                        </div>
                        <div class="boq_kcard_row">
                            <i class="fa fa-calendar text-muted me-2"/>
                            <field name="date"/>
                        </div>
                        <div class="boq_kcard_row" invisible="not user_id">
                            <i class="fa fa-user-circle text-muted me-2"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </div>
                    </div>

                    <!-- Category tags -->
                    <div class="boq_kcard_tags">
                        <field name="category_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"/>
                    </div>

                    <!-- Card footer -->
                    <div class="boq_kcard_footer">
                        <div class="boq_kcard_lines">
                            <i class="fa fa-list-ul text-muted me-1"/>
                            <field name="line_count"/> lines
                        </div>
                        <div class="boq_kcard_total">
                            <field name="total_amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </div>
                    </div>

                </t>
            </templates>
        </kanban>
    </field>
</record>

<!-- ═══════════════════════════════════════════════════════════════════════
     BOQ — SEARCH VIEW
═══════════════════════════════════════════════════════════════════════ -->
<record id="view_boq_boq_search" model="ir.ui.view">
    <field name="name">boq.boq.search</field>
    <field name="model">boq.boq</field>
    <field name="arch" type="xml">
        <search string="Search BOQ">
            <field name="name" string="Reference"/>
            <field name="partner_id"/>
            <field name="project_name"/>
            <field name="user_id"/>
            <field name="category_ids"/>
            <separator/>
            <filter string="My BOQs" name="my_boqs"
                    domain="[('user_id','=',uid)]"/>
            <filter string="Draft"     name="draft"
                    domain="[('state','=','draft')]"/>
            <filter string="Submitted" name="submitted"
                    domain="[('state','=','submitted')]"/>
            <filter string="Approved"  name="approved"
                    domain="[('state','=','approved')]"/>
            <filter string="Done"      name="done"
                    domain="[('state','=','done')]"/>
            <filter string="Urgent"    name="urgent"
                    domain="[('priority','=','1')]"/>
            <separator/>
            <filter string="This Month" name="this_month"
                    domain="[('date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
            <group expand="0" string="Group By">
                <filter string="Customer"  name="grp_partner"
                        context="{'group_by': 'partner_id'}"/>
                <filter string="Status"    name="grp_state"
                        context="{'group_by': 'state'}"/>
                <filter string="Category"  name="grp_cat"
                        context="{'group_by': 'category_ids'}"/>
                <filter string="Assigned To" name="grp_user"
                        context="{'group_by': 'user_id'}"/>
                <filter string="Month"     name="grp_month"
                        context="{'group_by': 'date:month'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ═══════════════════════════════════════════════════════════════════════
     BOQ — WINDOW ACTION
═══════════════════════════════════════════════════════════════════════ -->
<record id="action_boq_boq" model="ir.actions.act_window">
    <field name="name">Bills of Quantities</field>
    <field name="res_model">boq.boq</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="search_view_id" ref="view_boq_boq_search"/>
    <field name="context">{'search_default_draft': 1}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first Bill of Quantities!
        </p>
        <p>
            Link BOQs to customers, select work categories and fill in
            product lines per tab. Totals update automatically.
        </p>
    </field>
</record>

</odoo>
