<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ═══════════════════════════════════════════════════════════════════════
     BOQ — MAIN FORM VIEW (Odoo 19 Standard UI)
═══════════════════════════════════════════════════════════════════════ -->
<record id="view_boq_boq_form" model="ir.ui.view">
    <field name="name">boq.boq.form</field>
    <field name="model">boq.boq</field>
    <field name="arch" type="xml">
        <form string="Bill of Quantities">

            <!-- ── HEADER ──────────────────────────────────────────────── -->
            <header>
                <button name="action_submit"
                        string="Submit"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
                <button name="action_approve"
                        string="Approve"
                        type="object"
                        class="btn-primary"
                        groups="boq_management_v19.group_boq_manager"
                        invisible="state != 'submitted'"/>
                <button name="action_reject"
                        string="Reject"
                        type="object"
                        class="btn-secondary"
                        groups="boq_management_v19.group_boq_manager"
                        invisible="state not in ('submitted',)"/>
                <button name="action_done"
                        string="Mark Done"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'approved'"/>
                <button name="action_reset_draft"
                        string="Reset to Draft"
                        type="object"
                        class="btn-secondary"
                        invisible="state not in ('rejected', 'submitted')"/>
                <!--
                    CREATE RFQ — visible whenever at least 1 line exists.
                    Uses line_count (Integer) for reliable invisible evaluation
                    in Odoo 19 form-view expressions.
                -->
                <button name="action_create_rfq"
                        string="Create RFQ"
                        type="object"
                        class="btn-primary"
                        icon="fa-shopping-cart"
                        invisible="line_count == 0"
                        confirm="This will generate one RFQ per mapped vendor. Proceed?"/>
                <field name="state"
                       widget="statusbar"
                       statusbar_visible="draft,submitted,approved,done"/>
            </header>

            <sheet>
                <!-- ── SMART BUTTONS ──────────────────────────────────── -->
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-ul">
                        <field name="line_count" widget="statinfo" string="Lines"/>
                    </button>
                    <button name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="total_amount"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Total</span>
                        </div>
                    </button>
                    <button name="action_view_rfqs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart"
                            invisible="rfq_count == 0">
                        <field name="rfq_count" widget="statinfo" string="RFQs"/>
                    </button>
                </div>

                <!-- ── PRIORITY ───────────────────────────────────────── -->
                <field name="priority" widget="priority" class="float-start me-3 mt-1"/>

                <!-- ── TITLE ──────────────────────────────────────────── -->
                <div class="oe_title">
                    <label for="name" string="BOQ Reference"/>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>

                <!-- ── MAIN FIELDS ────────────────────────────────────── -->
                <group>
                    <group string="Customer &amp; Project">
                        <field name="partner_id"
                               options="{'no_create_edit': True}"/>
                        <field name="partner_shipping_id"/>
                        <field name="project_id"
                               options="{'no_create_edit': True}"/>
                        <field name="project_name"/>
                        <field name="project_location"/>
                    </group>
                    <group string="Details">
                        <field name="date"/>
                        <field name="validity_date"/>
                        <field name="user_id" widget="many2one_avatar_user"
                               options="{'no_create_edit': True}"/>
                        <field name="company_id"
                               options="{'no_create': True}"
                               groups="base.group_multi_company"/>
                    </group>
                </group>

                <!-- ── WORK CATEGORIES ───────────────────────────────── -->
                <group string="Work Categories">
                    <field name="category_ids"
                           widget="many2many_tags"
                           options="{'color_field': 'color', 'no_create_edit': True}"
                           placeholder="Select work categories to activate their tabs…"
                           nolabel="1"/>
                </group>

                <!-- ═══════════════════════════════════════════════════════
                     NOTEBOOK — one page per work category.
                     Each page is hidden when its boolean flag is False.
                     vendor_ids column on every line lets you map the vendor
                     that will receive the RFQ when "Create RFQ" is clicked.
                ═══════════════════════════════════════════════════════ -->
                <notebook>

                    <!-- ─────────────── ELECTRICAL ───────────────────── -->
                    <page string="Electrical" name="tab_electrical"
                          invisible="not show_electrical">
                        <field name="electrical_line_ids"
                               context="{'default_category_id': electrical_category_id}"
                               mode="list">
                            <list editable="bottom">
                                <field name="sequence" widget="handle" string="#"/>
                                <field name="product_id" required="1" string="Product"
                                       options="{'no_create_edit': False}"/>
                                <field name="product_name" string="Description"/>
                                <field name="product_type" string="Type"/>
                                <field name="qty" string="Qty"/>
                                <field name="uom_id" string="Unit" optional="show"/>
                                <field name="unit_price" string="Unit Price"/>
                                <field name="cost_price" string="Cost Price" optional="hide"/>
                                <field name="discount" string="Disc %" optional="hide"/>
                                <field name="tax_ids"
                                       widget="many2many_tags"
                                       string="Taxes"
                                       domain="[('type_tax_use','in',('purchase','all'))]"
                                       optional="show"/>
                                <field name="subtotal" string="Subtotal"
                                       readonly="1" sum="Tab Subtotal"/>
                                <field name="tax_amount" string="Tax Amt"
                                       readonly="1" optional="show"/>
                                <field name="total_value" string="Total (incl. Tax)"
                                       readonly="1" sum="Tab Total"/>
                                <field name="margin_percent" string="Margin %"
                                       readonly="1" optional="show"/>
                                <field name="vendor_ids"
                                       widget="many2many_tags"
                                       string="Vendors"
                                       domain="[('supplier_rank','>',0)]"
                                       options="{'no_create_edit': True}"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" string="Notes" optional="hide"/>
                                <field name="category_id" column_invisible="True"
                                       required="1"/>
                            </list>
                        </field>
                    </page>

                    <!-- ─────────────── CIVIL ─────────────────────────── -->
                    <page string="Civil" name="tab_civil"
                          invisible="not show_civil">
                        <field name="civil_line_ids"
