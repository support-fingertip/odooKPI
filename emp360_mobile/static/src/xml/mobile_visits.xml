<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ============================================================
     EMPLOYEE 360 — MOBILE VISITS SCREEN  v2.0
     Premium visit history with detail sheet
     ============================================================ -->

<t t-name="employee_mobile.MobileVisits">

    <!-- Loading -->
    <t t-if="state.loading">
        <div class="mobile360-loading">
            <div class="mobile360-spinner"/>
            <span class="mobile360-loading-text">Loading visits…</span>
        </div>
    </t>

    <t t-else="">

        <!-- ── Stats Hero ──────────────────────────────────── -->
        <div style="background:linear-gradient(135deg,#4cc9f0,#0077b6);padding:20px 16px 32px;position:relative;overflow:hidden;">
            <div class="mobile360-hero-decor"/>
            <div style="font-size:13px;color:rgba(255,255,255,0.85);font-weight:700;letter-spacing:0.3px;margin-bottom:14px;">
                <i class="fa fa-map-marker" style="margin-right:6px;"/>Visit History
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
                <div style="background:rgba(255,255,255,0.15);border-radius:14px;padding:14px 10px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:26px;font-weight:900;color:#fff;line-height:1;"><t t-esc="(state.summary || {}).total || state.filtered.length"/></div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-top:5px;">Total</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:14px;padding:14px 10px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:26px;font-weight:900;color:#fff;line-height:1;"><t t-esc="(state.summary || {}).completed || 0"/></div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-top:5px;">Done</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:14px;padding:14px 10px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:17px;font-weight:900;color:#fff;line-height:1;"><t t-esc="fmtMoney((state.summary || {}).sales || 0)"/></div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-top:5px;">Sales</div>
                </div>
            </div>
        </div>

        <!-- ── Filters ─────────────────────────────────────── -->
        <div style="padding:0 16px;margin-top:-14px;">

            <!-- Search -->
            <div class="mobile360-search-bar">
                <i class="fa fa-search mobile360-search-icon"/>
                <input class="mobile360-search-input" type="search" placeholder="Search customer, beat…"
                    t-on-input="onSearchInput"/>
            </div>

            <!-- Period chips -->
            <div class="mobile360-chips">
                <t t-foreach="[['today','Today'],['week','Week'],['month','Month'],['all','All']]" t-as="f" t-key="f[0]">
                    <button t-attf-class="mobile360-chip {{state.filter === f[0] ? 'active' : ''}}"
                        t-on-click="() => this.setFilter(f[0])"><t t-esc="f[1]"/></button>
                </t>
            </div>

            <!-- Status chips -->
            <div class="mobile360-chips" style="margin-bottom:14px;">
                <t t-foreach="[['all','All'],['completed','Done'],['in_progress','Live'],['planned','Planned'],['cancelled','Cancelled']]" t-as="s" t-key="s[0]">
                    <button t-attf-class="mobile360-chip {{state.statusFilter === s[0] ? 'active' : ''}}"
                        t-on-click="() => this.setStatusFilter(s[0])"><t t-esc="s[1]"/></button>
                </t>
            </div>

            <!-- Count pill -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.4px;">
                    <t t-esc="state.filtered.length"/> visits
                </div>
                <t t-if="state.filtered.length">
                    <div style="font-size:12px;color:#94a3b8;">
                        <i class="fa fa-sort-amount-desc" style="margin-right:4px;"/>Newest first
                    </div>
                </t>
            </div>

            <!-- Empty -->
            <t t-if="!state.filtered.length">
                <div class="mobile360-empty" style="padding:48px 0;">
                    <div class="mobile360-empty-icon" style="background:linear-gradient(135deg,#4cc9f0,#0077b6);color:#fff;">
                        <i class="fa fa-map-marker"/>
                    </div>
                    <div class="mobile360-empty-title">No Visits Found</div>
                    <div class="mobile360-empty-sub">Try changing the filter or date range</div>
                </div>
            </t>

            <!-- ── Visit Cards ────────────────────────────── -->
            <t t-foreach="state.filtered" t-as="visit" t-key="visit.id">
                <div class="mobile360-visit-card" t-on-click="() => this.openDetail(visit)"
                    style="cursor:pointer;position:relative;overflow:hidden;">

                    <!-- Status accent bar -->
                    <div t-attf-style="position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:4px 0 0 4px;background:{{visit.status === 'completed' ? '#06d6a0' : visit.status === 'in_progress' ? '#f77f00' : visit.status === 'cancelled' ? '#ef233c' : '#94a3b8'}};"/>

                    <div class="mobile360-visit-card-header" style="padding-left:12px;">
                        <!-- Customer avatar -->
                        <div class="mobile360-visit-avatar"
                            t-attf-style="background:{{getAvatarGradient(visit.partner_id?.[1])}};">
                            <t t-esc="getInitials(visit.partner_id?.[1])"/>
                        </div>

                        <!-- Info -->
                        <div class="mobile360-visit-info">
                            <div class="mobile360-visit-name">
                                <t t-esc="visit.partner_id?.[1] || 'Unknown Customer'"/>
                            </div>
                            <div class="mobile360-visit-meta">
                                <i class="fa fa-calendar-o"/>
                                <t t-esc="fmtDate(visit.actual_start_time)"/>
                                <t t-if="visit.beat_id?.[1]">
                                    <span style="color:#cbd5e1;margin:0 3px;">·</span>
                                    <i class="fa fa-road"/><t t-esc="' ' + visit.beat_id[1]"/>
                                </t>
                            </div>
                            <t t-if="isManager and visit.employee_id">
                                <div class="mobile360-visit-meta" style="margin-top:2px;color:#7209b7;">
                                    <i class="fa fa-user"/><t t-esc="' ' + (visit.employee_id?.[1] || '—')"/>
                                </div>
                            </t>
                        </div>

                        <!-- Badge + time -->
                        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
                            <span t-attf-class="mobile360-badge {{statusClass(visit.status)}}">
                                <i t-attf-class="fa {{statusIcon(visit.status)}}"/>
                                <t t-esc="' ' + statusLabel(visit.status)"/>
                            </span>
                            <div style="font-size:11px;color:#94a3b8;font-weight:600;">
                                <t t-esc="fmtTime(visit.actual_start_time)"/>
                            </div>
                        </div>
                    </div>

                    <!-- Stats row -->
                    <div class="mobile360-visit-stats" style="margin-top:10px;padding-left:12px;">
                        <div class="mobile360-visit-stat">
                            <div class="mobile360-visit-stat-val">
                                <t t-esc="visit.duration_display || '—'"/>
                            </div>
                            <div class="mobile360-visit-stat-lbl">Duration</div>
                        </div>
                        <div class="mobile360-visit-stat">
                            <div class="mobile360-visit-stat-val">
                                <t t-esc="visit.order_count or 0"/>
                            </div>
                            <div class="mobile360-visit-stat-lbl">Orders</div>
                        </div>
                        <div class="mobile360-visit-stat">
                            <div class="mobile360-visit-stat-val">
                                <t t-esc="fmtMoney(visit.total_order_amount)"/>
                            </div>
                            <div class="mobile360-visit-stat-lbl">Amount</div>
                        </div>
                        <div class="mobile360-visit-stat">
                            <div class="mobile360-visit-stat-val">
                                <t t-esc="visit.is_productive ? '✓' : '—'"/>
                            </div>
                            <div class="mobile360-visit-stat-lbl">Productive</div>
                        </div>
                    </div>
                </div>
            </t>

            <div style="height:24px;"/>
        </div>

        <!-- ── Visit Detail Bottom Sheet ──────────────────── -->
        <t t-if="state.showDetail">
            <div class="mobile360-overlay" t-on-click.self="closeDetail">
                <div class="mobile360-sheet" style="max-height:92vh;">
                    <div class="mobile360-sheet-handle"/>

                    <div class="mobile360-sheet-header">
                        <span class="mobile360-sheet-title">Visit Details</span>
                        <button class="mobile360-sheet-close" t-on-click="closeDetail">
                            <i class="fa fa-times"/>
                        </button>
                    </div>

                    <t t-if="state.detailLoading">
                        <div class="mobile360-loading" style="padding:40px;">
                            <div class="mobile360-spinner"/>
                            <span class="mobile360-loading-text">Loading details…</span>
                        </div>
                    </t>

                    <t t-elif="state.visitDetail">
                        <div class="mobile360-sheet-body" style="padding:0;overflow-y:auto;">

                            <!-- Hero gradient header -->
                            <div style="background:linear-gradient(135deg,#4cc9f0,#0077b6);padding:20px;color:#fff;position:relative;overflow:hidden;">
                                <div class="mobile360-hero-decor" style="opacity:0.3;"/>
                                <div style="font-size:11px;color:rgba(255,255,255,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;">
                                    Visit Record
                                </div>
                                <div style="font-size:22px;font-weight:900;color:#fff;line-height:1.2;">
                                    <t t-esc="state.visitDetail.partner_id?.[1]"/>
                                </div>
                                <div style="font-size:12px;color:rgba(255,255,255,0.75);margin-top:8px;display:flex;align-items:center;flex-wrap:wrap;gap:8px;">
                                    <span><i class="fa fa-calendar-o" style="margin-right:4px;"/><t t-esc="fmtDate(state.visitDetail.actual_start_time)"/></span>
                                    <span><i class="fa fa-clock-o" style="margin-right:4px;"/>
                                        <t t-esc="fmtTime(state.visitDetail.actual_start_time)"/> – <t t-esc="fmtTime(state.visitDetail.actual_end_time)"/>
                                    </span>
                                    <t t-if="state.visitDetail.duration_display">
                                        <span><i class="fa fa-hourglass-half" style="margin-right:4px;"/><t t-esc="state.visitDetail.duration_display"/></span>
                                    </t>
                                </div>
                                <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;">
                                    <span t-attf-class="mobile360-badge {{statusClass(state.visitDetail.status)}}"
                                        style="background:rgba(255,255,255,0.2);color:#fff;border:1px solid rgba(255,255,255,0.35);">
                                        <i t-attf-class="fa {{statusIcon(state.visitDetail.status)}}"/>
                                        <t t-esc="' ' + statusLabel(state.visitDetail.status)"/>
                                    </span>
                                    <t t-if="state.visitDetail.is_productive">
                                        <span class="mobile360-badge"
                                            style="background:rgba(6,214,160,0.2);color:#fff;border:1px solid rgba(6,214,160,0.4);">
                                            <i class="fa fa-check-circle"/> Productive
                                        </span>
                                    </t>
                                </div>
                            </div>

                            <!-- Quick stats bar -->
                            <div style="display:grid;grid-template-columns:repeat(3,1fr);border-bottom:1px solid #e2e8f0;">
                                <div style="padding:14px 10px;text-align:center;border-right:1px solid #e2e8f0;">
                                    <div style="font-size:22px;font-weight:900;color:#0f172a;"><t t-esc="state.visitDetail.order_count or 0"/></div>
                                    <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.4px;margin-top:3px;">Orders</div>
                                </div>
                                <div style="padding:14px 10px;text-align:center;border-right:1px solid #e2e8f0;">
                                    <div style="font-size:17px;font-weight:900;color:#0f172a;"><t t-esc="fmtMoney(state.visitDetail.total_order_amount)"/></div>
                                    <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.4px;margin-top:3px;">Sales</div>
                                </div>
                                <div style="padding:14px 10px;text-align:center;">
                                    <div style="font-size:17px;font-weight:900;color:#0f172a;"><t t-esc="fmtMoney(state.visitDetail.total_collected)"/></div>
                                    <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.4px;margin-top:3px;">Collected</div>
                                </div>
                            </div>

                            <!-- Details rows -->
                            <div style="padding:16px;">

                                <t t-if="state.visitDetail.beat_id?.[1]">
                                    <div class="mobile360-stat-row">
                                        <span class="mobile360-stat-label"><i class="fa fa-road"/> Beat</span>
                                        <span class="mobile360-stat-value"><t t-esc="state.visitDetail.beat_id[1]"/></span>
                                    </div>
                                </t>
                                <t t-if="state.visitDetail.travel_type">
                                    <div class="mobile360-stat-row">
                                        <span class="mobile360-stat-label"><i class="fa fa-car"/> Travel</span>
                                        <span class="mobile360-stat-value"><t t-esc="state.visitDetail.travel_type"/></span>
                                    </div>
                                </t>
                                <t t-if="state.visitDetail.checklist_total">
                                    <div class="mobile360-stat-row">
                                        <span class="mobile360-stat-label"><i class="fa fa-check-square-o"/> Checklist</span>
                                        <span class="mobile360-stat-value">
                                            <t t-esc="state.visitDetail.checklist_done or 0"/>/<t t-esc="state.visitDetail.checklist_total"/> done
                                        </span>
                                    </div>
                                </t>
                                <t t-if="state.visitDetail.visit_comments">
                                    <div class="mobile360-stat-row" style="flex-direction:column;align-items:flex-start;gap:6px;">
                                        <span class="mobile360-stat-label"><i class="fa fa-comment-o"/> Comments</span>
                                        <div style="background:#f8fafc;border-radius:10px;padding:10px 12px;width:100%;font-size:13px;color:#334155;line-height:1.5;">
                                            <t t-esc="state.visitDetail.visit_comments"/>
                                        </div>
                                    </div>
                                </t>

                                <!-- Collections sub-section -->
                                <t t-if="state.visitDetail.collections and state.visitDetail.collections.length">
                                    <div style="margin-top:18px;">
                                        <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">
                                            <i class="fa fa-money" style="margin-right:5px;color:#06d6a0;"/>Collections
                                        </div>
                                        <t t-foreach="state.visitDetail.collections" t-as="coll" t-key="coll.id">
                                            <div style="background:#f0fdf4;border-radius:12px;padding:12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;border:1px solid #bbf7d0;">
                                                <div>
                                                    <div style="font-size:15px;font-weight:800;color:#015c3c;">
                                                        <t t-esc="fmtMoney(coll.amount)"/>
                                                    </div>
                                                    <div style="font-size:11px;color:#64748b;margin-top:2px;">
                                                        <t t-esc="coll.payment_mode"/> · <t t-esc="coll.date"/>
                                                    </div>
                                                </div>
                                                <span class="mobile360-badge success">Confirmed</span>
                                            </div>
                                        </t>
                                    </div>
                                </t>

                                <!-- Orders sub-section -->
                                <t t-if="state.visitDetail.orders and state.visitDetail.orders.length">
                                    <div style="margin-top:18px;">
                                        <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">
                                            <i class="fa fa-shopping-cart" style="margin-right:5px;color:#4361ee;"/>Orders
                                        </div>
                                        <t t-foreach="state.visitDetail.orders" t-as="order" t-key="order.id">
                                            <div style="background:#f0f4ff;border-radius:12px;padding:12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;border:1px solid #c7d2fe;">
                                                <div>
                                                    <div style="font-size:13px;font-weight:700;color:#4361ee;"><t t-esc="order.name"/></div>
                                                    <div style="font-size:12px;color:#64748b;margin-top:2px;"><t t-esc="fmtMoney(order.amount_total)"/></div>
                                                </div>
                                                <span t-attf-class="mobile360-badge {{order.state === 'sale' ? 'success' : order.state === 'done' ? 'info' : 'warning'}}">
                                                    <t t-esc="order.state === 'sale' ? 'Confirmed' : order.state === 'done' ? 'Done' : order.state"/>
                                                </span>
                                            </div>
                                        </t>
                                    </div>
                                </t>

                                <!-- Tickets sub-section -->
                                <t t-if="state.visitDetail.tickets and state.visitDetail.tickets.length">
                                    <div style="margin-top:18px;">
                                        <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">
                                            <i class="fa fa-ticket" style="margin-right:5px;color:#f77f00;"/>Support Tickets
                                        </div>
                                        <t t-foreach="state.visitDetail.tickets" t-as="ticket" t-key="ticket.id">
                                            <div style="background:#fff7ed;border-radius:12px;padding:12px;margin-bottom:8px;border:1px solid #fed7aa;">
                                                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
                                                    <div style="flex:1;">
                                                        <div style="font-size:13px;font-weight:700;color:#0f172a;"><t t-esc="ticket.subject"/></div>
                                                        <div style="font-size:11px;color:#64748b;margin-top:3px;"><t t-esc="ticket.category"/> · <t t-esc="ticket.priority"/></div>
                                                    </div>
                                                    <span t-attf-class="mobile360-badge {{priorityClass(ticket.priority)}}">
                                                        <t t-esc="ticket.state"/>
                                                    </span>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>

                                <div style="height:20px;"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </t>
</t>

</templates>
