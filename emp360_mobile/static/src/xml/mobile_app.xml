<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ============================================================
     EMPLOYEE 360 — SCREEN ERROR BOUNDARY
     Catches OWL render crashes and shows cache-clear recovery UI
     ============================================================ -->

<t t-name="employee_mobile.ScreenErrorBoundary">
    <t t-if="state.error">
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;padding:32px 24px;text-align:center;">
            <div style="width:72px;height:72px;border-radius:20px;background:#fee2e2;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <i class="fa fa-exclamation-triangle" style="font-size:28px;color:#ef233c;"/>
            </div>
            <div style="font-size:19px;font-weight:800;color:#0f172a;letter-spacing:-0.3px;">Screen Failed to Load</div>
            <div style="font-size:14px;color:#64748b;margin:8px 0 8px;line-height:1.5;">
                The app asset cache is outdated. Clear it and the app will reload with the latest version.
            </div>
            <div style="font-size:12px;color:#94a3b8;background:#f8fafc;border-radius:8px;padding:8px 12px;margin-bottom:24px;font-family:monospace;max-width:300px;word-break:break-all;">
                <t t-esc="state.errorMsg"/>
            </div>
            <a href="/emp360/clear-assets"
               style="display:block;background:linear-gradient(135deg,#4361ee,#3a0ca3);color:#fff;padding:14px 32px;border-radius:14px;font-weight:700;text-decoration:none;font-size:15px;box-shadow:0 4px 16px rgba(67,97,238,0.35);">
                <i class="fa fa-refresh" style="margin-right:8px;"/>
                Clear Cache &amp; Reload
            </a>
            <div style="margin-top:16px;font-size:12px;color:#94a3b8;">
                Or navigate to <strong>/emp360/clear-assets</strong> in your browser
            </div>
        </div>
    </t>
    <t t-else="">
        <t t-slot="default"/>
    </t>
</t>

<!-- ============================================================
     EMPLOYEE 360 — MOBILE APP SHELL  v2.0
     Status bar · Top bar · Content · Bottom nav
     ============================================================ -->

<t t-name="employee_mobile.MobileApp">
<div class="mobile360-root">

    <!-- ── Splash / Loading ──────────────────────────────────── -->
    <t t-if="state.loading">
        <div class="mobile360-splash">
            <div class="mobile360-splash-logo"><i class="fa fa-briefcase"/></div>
            <div class="mobile360-splash-title">Employee 360</div>
            <div class="mobile360-splash-sub">Loading your workspace…</div>
            <div class="mobile360-spinner" style="border-color:rgba(255,255,255,0.15);border-top-color:#4361ee;margin-top:8px;"/>
        </div>
    </t>

    <!-- ── Error ─────────────────────────────────────────────── -->
    <t t-elif="state.initError">
        <div class="mobile360-empty" style="flex:1;background:#f2f5f9;">
            <div class="mobile360-empty-icon" style="background:#fee2e2;color:#ef233c;">
                <i class="fa fa-exclamation-triangle"/>
            </div>
            <div class="mobile360-empty-title">Connection Error</div>
            <div class="mobile360-empty-sub">Unable to load your workspace. Check your connection and try again.</div>
        </div>
    </t>

    <!-- ── App Content ───────────────────────────────────────── -->
    <t t-else="">

        <!-- Top Bar -->
        <div class="mobile360-topbar" t-attf-style="background:{{topbarGradient()}};">
            <!-- Left: back button or avatar -->
            <t t-if="canGoBack">
                <button class="mobile360-topbar-btn" t-on-click="goBack">
                    <i class="fa fa-arrow-left"/>
                </button>
            </t>
            <t t-else="">
                <div class="mobile360-avatar-chip">
                    <t t-esc="employeeInitials"/>
                </div>
            </t>

            <!-- Center: title + date -->
            <div class="mobile360-topbar-center">
                <span class="mobile360-topbar-title"><t t-esc="currentTitle()"/></span>
                <span class="mobile360-topbar-subtitle"><t t-esc="todayDate"/></span>
            </div>

            <!-- Right: refresh -->
            <button class="mobile360-topbar-btn" t-on-click="onRefresh">
                <i class="fa fa-refresh"/>
            </button>
        </div>

        <!-- Scrollable Content -->
        <div class="mobile360-content">
            <div t-if="state.activeScreen === 'home'" class="mobile360-screen">
                <MobileHome
                    employeeId="state.employeeId"
                    employeeName="state.employeeName"
                    isManager="state.isManager"
                    employees="state.employees"
                    onNavigate.bind="onNavigate"
                />
            </div>

            <div t-if="state.activeScreen === 'today'" class="mobile360-screen">
                <MobileToday employeeId="state.employeeId"/>
            </div>

            <div t-if="state.activeScreen === 'visits'" class="mobile360-screen">
                <ScreenErrorBoundary>
                    <t t-set-slot="default">
                        <MobileVisits employeeId="state.employeeId" isManager="state.isManager"/>
                    </t>
                </ScreenErrorBoundary>
            </div>

            <div t-if="state.activeScreen === 'orders'" class="mobile360-screen">
                <ScreenErrorBoundary>
                    <t t-set-slot="default">
                        <MobileOrders employeeId="state.employeeId" isManager="state.isManager"/>
                    </t>
                </ScreenErrorBoundary>
            </div>

            <div t-if="state.activeScreen === 'team' and state.isManager" class="mobile360-screen">
                <ScreenErrorBoundary>
                    <t t-set-slot="default">
                        <MobileManager employeeId="state.employeeId"/>
                    </t>
                </ScreenErrorBoundary>
            </div>

            <div t-if="state.activeScreen === 'profile'" class="mobile360-screen">
                <MobileProfile employeeId="state.employeeId" isManager="state.isManager"/>
            </div>
        </div>

        <!-- Bottom Navigation -->
        <nav class="mobile360-bottom-nav">
            <t t-foreach="navItems" t-as="nav" t-key="nav.id">
                <button
                    t-attf-class="mobile360-nav-item {{state.activeScreen === nav.id ? 'active' : ''}}"
                    t-on-click="() => this.navigate(nav.id)">
                    <i t-attf-class="fa {{nav.icon}} mobile360-nav-icon"/>
                    <span class="mobile360-nav-label"><t t-esc="nav.label"/></span>
                    <t t-if="getBadge(nav.id)">
                        <span class="mobile360-nav-badge"><t t-esc="getBadge(nav.id)"/></span>
                    </t>
                </button>
            </t>
        </nav>
    </t>
</div>
</t>

</templates>
