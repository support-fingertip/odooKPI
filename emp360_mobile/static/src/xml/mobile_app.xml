<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ============================================================
     EMPLOYEE 360 — MOBILE APP SHELL  v3.0
     Premium iOS/Android-style shell with enhanced navigation
     ============================================================ -->

<t t-name="employee_mobile.MobileApp">
<div class="mobile360-root">

    <!-- ── Splash / Loading ──────────────────────────────────── -->
    <t t-if="state.loading">
        <div class="mobile360-splash">
            <div class="mobile360-splash-logo">
                <i class="fa fa-street-view" style="font-size:42px;"/>
            </div>
            <div class="mobile360-splash-title">Employee 360</div>
            <div class="mobile360-splash-sub">Loading your workspace…</div>
            <div class="mobile360-spinner" style="border-color:rgba(255,255,255,0.15);border-top-color:#4361ee;margin-top:16px;width:32px;height:32px;"/>
        </div>
    </t>

    <!-- ── Error ─────────────────────────────────────────────── -->
    <t t-elif="state.initError">
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#f2f5f9;padding:40px;text-align:center;gap:14px;">
            <div style="width:72px;height:72px;border-radius:22px;background:#fee2e2;display:flex;align-items:center;justify-content:center;font-size:28px;color:#ef233c;">
                <i class="fa fa-exclamation-triangle"/>
            </div>
            <div style="font-size:18px;font-weight:800;color:#0f172a;">Connection Error</div>
            <div style="font-size:14px;color:#64748b;max-width:260px;line-height:1.5;">Unable to load your workspace. Check your connection and try again.</div>
        </div>
    </t>

    <!-- ── App Content ───────────────────────────────────────── -->
    <t t-else="">

        <!-- ── Top Bar ───────────────────────────────────────── -->
        <div class="mobile360-topbar" t-attf-style="background:{{topbarGradient()}};">
            <!-- Left: back or avatar -->
            <t t-if="canGoBack">
                <button class="mobile360-topbar-btn" t-on-click="goBack">
                    <i class="fa fa-arrow-left"/>
                </button>
            </t>
            <t t-else="">
                <div class="mobile360-avatar-chip" style="display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;cursor:default;">
                    <t t-esc="employeeInitials"/>
                </div>
            </t>

            <!-- Center: title + date -->
            <div class="mobile360-topbar-center">
                <span class="mobile360-topbar-title"><t t-esc="currentTitle()"/></span>
                <span class="mobile360-topbar-subtitle">
                    <i class="fa fa-calendar-o" style="margin-right:4px;opacity:0.7;"/>
                    <t t-esc="todayDate"/>
                </span>
            </div>

            <!-- Right: refresh -->
            <button class="mobile360-topbar-btn" t-on-click="onRefresh" title="Refresh">
                <i class="fa fa-refresh"/>
            </button>
        </div>

        <!-- ── Scrollable Content ─────────────────────────────── -->
        <div class="mobile360-content">
            <div t-if="state.activeScreen === 'home'" class="mobile360-screen">
                <MobileHome
                    employeeId="state.employeeId"
                    employeeName="state.employeeName"
                    isManager="state.isManager"
                    employees="state.employees"
                    onNavigate.bind="onNavigate"
                />
            </div>

            <div t-if="state.activeScreen === 'today'" class="mobile360-screen">
                <MobileToday employeeId="state.employeeId"/>
            </div>

            <div t-if="state.activeScreen === 'visits'" class="mobile360-screen">
                <MobileVisits employeeId="state.employeeId" isManager="state.isManager"/>
            </div>

            <div t-if="state.activeScreen === 'orders'" class="mobile360-screen">
                <MobileOrders employeeId="state.employeeId" isManager="state.isManager"/>
            </div>

            <div t-if="state.activeScreen === 'team' and state.isManager" class="mobile360-screen">
                <MobileManager employeeId="state.employeeId"/>
            </div>

            <div t-if="state.activeScreen === 'profile'" class="mobile360-screen">
                <MobileProfile employeeId="state.employeeId" isManager="state.isManager"/>
            </div>
        </div>

        <!-- ── Bottom Navigation v3 ──────────────────────────── -->
        <nav class="mobile360-bottom-nav">
            <t t-foreach="navItems" t-as="nav" t-key="nav.id">
                <button
                    t-attf-class="mobile360-nav-item {{state.activeScreen === nav.id ? 'active' : ''}}"
                    t-on-click="() => this.navigate(nav.id)">

                    <div style="position:relative;display:inline-flex;flex-direction:column;align-items:center;gap:3px;">
                        <i t-attf-class="fa {{nav.icon}} mobile360-nav-icon" style="font-size:21px;"/>
                        <span class="mobile360-nav-label"><t t-esc="nav.label"/></span>

                        <!-- Badge dot -->
                        <t t-if="getBadge(nav.id)">
                            <span class="mobile360-nav-badge"><t t-esc="getBadge(nav.id)"/></span>
                        </t>

                        <!-- Active dot indicator at bottom -->
                        <t t-if="state.activeScreen === nav.id">
                            <div style="width:4px;height:4px;border-radius:50%;background:var(--m-primary);margin-top:1px;"/>
                        </t>
                    </div>
                </button>
            </t>
        </nav>
    </t>
</div>
</t>

</templates>
