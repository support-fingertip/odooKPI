<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ============================================================
     EMPLOYEE 360 — MOBILE HOME  v2.0
     Field User + Manager dashboards
     ============================================================ -->

<t t-name="employee_mobile.MobileHome">

    <!-- Loading -->
    <t t-if="state.loading">
        <div class="mobile360-loading" style="min-height:60vh;">
            <div class="mobile360-spinner"/>
            <span class="mobile360-loading-text">Loading dashboard…</span>
        </div>
    </t>

    <!-- ════════════════════════════════════════════════
         FIELD USER HOME
         ════════════════════════════════════════════════ -->
    <t t-elif="!isManager">

        <!-- Hero Header -->
        <div class="mobile360-hero" style="background:linear-gradient(150deg,#0b0c1e 0%,#161732 55%,#0f3460 100%);padding-bottom:40px;">
            <div class="mobile360-hero-decor"/>
            <div class="mobile360-hero-decor-2"/>
            <div class="mobile360-hero-greeting">
                <i t-attf-class="fa {{greetingIcon}}"/>
                <t t-esc="greeting"/>
            </div>
            <div class="mobile360-hero-name"><t t-esc="employeeFirstName"/> 👋</div>
            <div class="mobile360-hero-date"><t t-esc="todayDateStr"/></div>

            <!-- Attendance badge -->
            <t t-if="state.attendance.checkedIn">
                <div class="mobile360-hero-badge" style="background:rgba(6,214,160,0.18);border-color:rgba(6,214,160,0.4);">
                    <span style="width:8px;height:8px;border-radius:50%;background:#06d6a0;animation:m-pulse 2s ease-in-out infinite;display:inline-block;"/>
                    Checked-in at <t t-esc="fmtTime(state.attendance.checkIn)"/>
                    <t t-if="state.attendance.workedHours">
                        · <t t-esc="state.attendance.workedHours"/>
                    </t>
                </div>
            </t>
            <t t-else="">
                <div class="mobile360-hero-badge" style="background:rgba(239,35,60,0.18);border-color:rgba(239,35,60,0.4);">
                    <i class="fa fa-clock-o"/>
                    Not checked in yet — tap Workday to start
                </div>
            </t>
        </div>

        <!-- Active Visit Banner -->
        <t t-if="state.activeVisit">
            <div class="mobile360-section" style="margin-top:-14px;padding-top:0;">
                <div class="mobile360-active-visit" t-on-click="() => this.navigateTo('today')">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div>
                            <div style="font-size:11px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">ACTIVE VISIT</div>
                            <div style="font-size:18px;font-weight:800;color:#fff;margin-top:4px;letter-spacing:-0.3px;">
                                <t t-esc="state.activeVisit.partner_id?.[1] || 'Customer'"/>
                            </div>
                            <div style="font-size:12px;color:rgba(255,255,255,0.8);margin-top:4px;">
                                <i class="fa fa-clock-o"/> Started <t t-esc="fmtTime(state.activeVisit.actual_start_time)"/>
                            </div>
                        </div>
                        <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                            <div class="mobile360-pulse"/>
                            <div style="font-size:10px;font-weight:800;color:#fff;letter-spacing:0.5px;">LIVE</div>
                            <i class="fa fa-chevron-right" style="color:rgba(255,255,255,0.7);font-size:14px;"/>
                        </div>
                    </div>
                </div>
            </div>
        </t>

        <!-- KPI Cards — This Month -->
        <div class="mobile360-section" style="margin-top:16px;">
            <div class="mobile360-section-header">
                <span class="mobile360-section-title">This Month</span>
                <button class="mobile360-section-link" t-on-click="() => this.navigateTo('visits')">View All →</button>
            </div>
            <div class="mobile360-kpi-grid">
                <!-- Today Visits -->
                <div class="mobile360-kpi-card blue" t-on-click="() => this.navigateTo('visits')">
                    <div class="mobile360-kpi-icon m-bg-primary"><i class="fa fa-map-marker"/></div>
                    <div class="mobile360-kpi-value"><t t-esc="state.kpi.visits_today"/></div>
                    <div class="mobile360-kpi-label">Today</div>
                    <div class="mobile360-kpi-change up">
                        <i class="fa fa-calendar"/> <t t-esc="state.kpi.visits_month"/> this month
                    </div>
                </div>
                <!-- Beats -->
                <div class="mobile360-kpi-card green" t-on-click="() => this.navigateTo('today')">
                    <div class="mobile360-kpi-icon m-bg-success"><i class="fa fa-road"/></div>
                    <div class="mobile360-kpi-value"><t t-esc="state.kpi.beats_completed"/>/<t t-esc="state.kpi.beats_today"/></div>
                    <div class="mobile360-kpi-label">Beats Done</div>
                    <div class="mobile360-kpi-change up">
                        <i class="fa fa-percent"/> <t t-esc="beatProgressPct"/>% done
                    </div>
                </div>
                <!-- Orders -->
                <div class="mobile360-kpi-card orange" t-on-click="() => this.navigateTo('orders')">
                    <div class="mobile360-kpi-icon m-bg-warning"><i class="fa fa-shopping-cart"/></div>
                    <div class="mobile360-kpi-value"><t t-esc="state.kpi.orders_month"/></div>
                    <div class="mobile360-kpi-label">Orders</div>
                    <div class="mobile360-kpi-change up"><i class="fa fa-arrow-up"/> Month</div>
                </div>
                <!-- Sales -->
                <div class="mobile360-kpi-card purple" t-on-click="() => this.navigateTo('orders')">
                    <div class="mobile360-kpi-icon m-bg-purple"><i class="fa fa-rupee"/></div>
                    <div class="mobile360-kpi-value" style="font-size:18px;"><t t-esc="fmtMoney(state.kpi.sales_month)"/></div>
                    <div class="mobile360-kpi-label">Sales</div>
                    <div class="mobile360-kpi-change up"><i class="fa fa-arrow-up"/> Revenue</div>
                </div>
            </div>

            <!-- Collections + KPI Achievement -->
            <div class="mobile360-kpi-grid" style="grid-template-columns:1fr 1fr;">
                <div class="mobile360-kpi-card teal">
                    <div class="mobile360-kpi-icon m-bg-teal"><i class="fa fa-money"/></div>
                    <div class="mobile360-kpi-value" style="font-size:18px;"><t t-esc="fmtMoney(state.kpi.collections)"/></div>
                    <div class="mobile360-kpi-label">Collections</div>
                </div>
                <div class="mobile360-kpi-card">
                    <div class="mobile360-kpi-icon" t-attf-style="background:linear-gradient(135deg,{{achievementColor}},{{achievementColor}}aa);">
                        <i class="fa fa-trophy"/>
                    </div>
                    <div class="mobile360-kpi-value" t-attf-style="color:{{achievementColor}};font-size:20px;">
                        <t t-esc="state.kpi.achievement"/>%
                    </div>
                    <div class="mobile360-kpi-label">KPI Target</div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="mobile360-section" style="margin-top:4px;">
            <div class="mobile360-section-title" style="margin-bottom:14px;">Quick Actions</div>
            <div class="mobile360-quick-actions">
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('today')">
                    <div class="mobile360-quick-icon m-bg-success"><i class="fa fa-play-circle"/></div>
                    <span class="mobile360-quick-label">Start Day</span>
                </button>
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('today')">
                    <div class="mobile360-quick-icon m-bg-primary"><i class="fa fa-map-marker"/></div>
                    <span class="mobile360-quick-label">New Visit</span>
                </button>
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('orders')">
                    <div class="mobile360-quick-icon m-bg-warning"><i class="fa fa-shopping-cart"/></div>
                    <span class="mobile360-quick-label">Orders</span>
                </button>
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('profile')">
                    <div class="mobile360-quick-icon m-bg-purple"><i class="fa fa-trophy"/></div>
                    <span class="mobile360-quick-label">My KPI</span>
                </button>
            </div>
        </div>

        <!-- ── My Location Card ──────────────────────────────────────── -->
        <div class="mobile360-section" style="margin-top:4px;">
            <div class="mobile360-section-header">
                <span class="mobile360-section-title">
                    <i class="fa fa-map-marker" style="color:#4361ee;margin-right:6px;"/>My Location
                </span>
                <t t-if="state.locationInfo.lat">
                    <a t-att-href="mapsUrl" target="_blank" class="mobile360-section-link">Open Maps →</a>
                </t>
            </div>

            <!-- GPS acquired -->
            <t t-if="state.locationInfo.lat">
                <div class="mobile360-location-card">
                    <div class="mobile360-location-icon">
                        <i class="fa fa-crosshairs"/>
                    </div>
                    <div class="mobile360-location-info">
                        <div class="mobile360-location-coords">
                            <t t-esc="state.locationInfo.lat"/>°,
                            <t t-esc="state.locationInfo.lng"/>°
                        </div>
                        <div class="mobile360-location-sub">
                            <i class="fa fa-dot-circle-o" style="color:#06d6a0;margin-right:3px;"/>
                            Accuracy ±<t t-esc="state.locationInfo.accuracy"/>m
                            <t t-if="state.attendance.checkinCity">
                                <span style="margin:0 5px;opacity:0.4;">·</span>
                                <i class="fa fa-building-o" style="margin-right:3px;"/>
                                <t t-esc="state.attendance.checkinCity"/>
                            </t>
                        </div>
                    </div>
                    <a t-att-href="mapsUrl" target="_blank" class="mobile360-location-btn">
                        <i class="fa fa-external-link"/>
                    </a>
                </div>
            </t>

            <!-- GPS loading -->
            <t t-elif="state.locationInfo.loading">
                <div class="mobile360-location-card mobile360-location-card--loading">
                    <div class="mobile360-location-icon" style="background:linear-gradient(135deg,#64748b,#94a3b8);">
                        <i class="fa fa-spinner fa-spin"/>
                    </div>
                    <div class="mobile360-location-info">
                        <div class="mobile360-location-coords" style="color:rgba(255,255,255,0.6);">Acquiring GPS…</div>
                        <div class="mobile360-location-sub">Please wait</div>
                    </div>
                </div>
            </t>

            <!-- GPS error / denied -->
            <t t-elif="state.locationInfo.error">
                <div class="mobile360-location-card mobile360-location-card--error">
                    <div class="mobile360-location-icon" style="background:linear-gradient(135deg,#ef233c,#d62828);">
                        <i class="fa fa-exclamation-triangle"/>
                    </div>
                    <div class="mobile360-location-info">
                        <div class="mobile360-location-coords" style="color:rgba(255,255,255,0.85);">
                            <t t-esc="state.locationInfo.error"/>
                        </div>
                        <div class="mobile360-location-sub">Enable location in browser settings</div>
                    </div>
                    <button class="mobile360-location-btn" t-on-click="_loadCurrentLocation"
                        style="background:rgba(255,255,255,0.12);">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>
            </t>

            <!-- Check-in location from attendance -->
            <t t-if="state.attendance.checkedIn and state.attendance.lat and !state.locationInfo.lat">
                <div class="mobile360-location-badge-row" style="margin-top:8px;">
                    <i class="fa fa-sign-in" style="color:#4361ee;margin-right:6px;font-size:13px;"/>
                    <span style="font-size:12px;color:#475569;">Checked-in at:
                        <strong><t t-esc="state.attendance.lat"/>°, <t t-esc="state.attendance.lng"/>°</strong>
                    </span>
                </div>
            </t>
        </div>

        <!-- Today's Beat -->
        <t t-if="state.currentBeat">
            <div class="mobile360-section" style="margin-top:4px;">
                <div class="mobile360-section-header">
                    <span class="mobile360-section-title">Today's Beat</span>
                    <button class="mobile360-section-link" t-on-click="() => this.navigateTo('today')">Open →</button>
                </div>
                <div class="mobile360-beat-card" t-on-click="() => this.navigateTo('today')">
                    <div class="mobile360-hero-decor" style="opacity:0.5;"/>
                    <div class="mobile360-beat-header">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                            <div class="mobile360-beat-name"><t t-esc="state.currentBeat.name"/></div>
                            <span class="mobile360-badge" style="background:rgba(255,255,255,0.15);color:#fff;font-size:10px;">
                                # <t t-esc="state.currentBeat.beat_number || '—'"/>
                            </span>
                        </div>
                        <div class="mobile360-beat-meta">
                            <i class="fa fa-users"/> <t t-esc="state.currentBeat.customer_count || 0"/> customers
                            <span style="width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,0.4);display:inline-block;"/>
                            <t t-esc="state.kpi.beats_completed"/> beat<t t-if="state.kpi.beats_completed !== 1">s</t> done
                        </div>
                        <div class="mobile360-beat-progress" style="margin-top:12px;">
                            <div class="mobile360-beat-progress-bar" t-attf-style="width:{{beatProgressPct}}%;"/>
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-top:6px;">
                            <span style="font-size:11px;color:rgba(255,255,255,0.6);">Progress</span>
                            <span style="font-size:11px;font-weight:800;color:#06d6a0;"><t t-esc="beatProgressPct"/>%</span>
                        </div>
                    </div>
                </div>
            </div>
        </t>

        <div class="m-spacer-16"/>
    </t>

    <!-- ════════════════════════════════════════════════
         MANAGER HOME / DASHBOARD
         ════════════════════════════════════════════════ -->
    <t t-else="">

        <!-- Manager Hero -->
        <div class="mobile360-manager-hero" style="background:linear-gradient(150deg,#0b0c1e 0%,#161732 55%,#0f3460 100%);padding-bottom:44px;">
            <div class="mobile360-hero-decor"/>
            <div style="font-size:12px;color:rgba(255,255,255,0.6);font-weight:700;text-transform:uppercase;letter-spacing:0.6px;">Manager Dashboard</div>
            <div class="mobile360-hero-name" style="font-size:22px;margin-top:4px;">Team Overview</div>
            <div class="mobile360-hero-date"><t t-esc="todayDateStr"/></div>
            <div class="mobile360-team-live" style="margin-top:10px;">
                <div class="mobile360-team-live-dot"/>
                <span style="font-size:13px;color:rgba(255,255,255,0.9);font-weight:700;">
                    <t t-esc="state.teamStats.active"/> active · <t t-esc="state.teamStats.total"/> total
                </span>
            </div>
        </div>

        <!-- Team KPI Grid -->
        <div class="mobile360-section" style="margin-top:-16px;">
            <div class="mobile360-kpi-grid">
                <div class="mobile360-kpi-card blue" t-on-click="() => this.navigateTo('team')">
                    <div class="mobile360-kpi-icon m-bg-primary"><i class="fa fa-users"/></div>
                    <div class="mobile360-kpi-value"><t t-esc="state.teamStats.active"/>/<t t-esc="state.teamStats.total"/></div>
                    <div class="mobile360-kpi-label">Field Active</div>
                </div>
                <div class="mobile360-kpi-card green" t-on-click="() => this.navigateTo('visits')">
                    <div class="mobile360-kpi-icon m-bg-success"><i class="fa fa-check-circle"/></div>
                    <div class="mobile360-kpi-value"><t t-esc="state.teamStats.visits_today"/></div>
                    <div class="mobile360-kpi-label">Visits Done</div>
                </div>
                <div class="mobile360-kpi-card orange" t-on-click="() => this.navigateTo('orders')">
                    <div class="mobile360-kpi-icon m-bg-warning"><i class="fa fa-shopping-cart"/></div>
                    <div class="mobile360-kpi-value"><t t-esc="state.teamStats.orders_today"/></div>
                    <div class="mobile360-kpi-label">Orders</div>
                </div>
                <div class="mobile360-kpi-card purple" t-on-click="() => this.navigateTo('team')">
                    <div class="mobile360-kpi-icon m-bg-purple"><i class="fa fa-rupee"/></div>
                    <div class="mobile360-kpi-value" style="font-size:18px;"><t t-esc="fmtMoney(state.teamStats.sales_today)"/></div>
                    <div class="mobile360-kpi-label">Sales Today</div>
                </div>
            </div>
        </div>

        <!-- Top Performers -->
        <t t-if="state.topPerformers.length">
            <div class="mobile360-section" style="margin-top:4px;">
                <div class="mobile360-section-header">
                    <span class="mobile360-section-title">Top Performers</span>
                    <button class="mobile360-section-link" t-on-click="() => this.navigateTo('team')">See All →</button>
                </div>
                <div class="mobile360-list">
                    <t t-foreach="state.topPerformers" t-as="emp" t-key="emp.id">
                        <div class="mobile360-list-item">
                            <div class="mobile360-list-icon" t-attf-style="background:{{getAvatarGradient(emp.name)}};font-weight:800;font-size:13px;">
                                <t t-esc="getInitials(emp.name)"/>
                            </div>
                            <div class="mobile360-list-content">
                                <div class="mobile360-list-title"><t t-esc="emp.name"/></div>
                                <div class="mobile360-list-sub"><t t-esc="emp.visits"/> visits completed today</div>
                            </div>
                            <div class="mobile360-list-right">
                                <span class="mobile360-badge success"><t t-esc="emp.visits"/> ✓</span>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>

        <!-- Quick Actions (Manager) -->
        <div class="mobile360-section" style="margin-top:8px;">
            <div class="mobile360-section-title" style="margin-bottom:14px;">Quick Actions</div>
            <div class="mobile360-quick-actions">
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('team')">
                    <div class="mobile360-quick-icon m-bg-primary"><i class="fa fa-users"/></div>
                    <span class="mobile360-quick-label">My Team</span>
                </button>
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('visits')">
                    <div class="mobile360-quick-icon m-bg-success"><i class="fa fa-map-marker"/></div>
                    <span class="mobile360-quick-label">All Visits</span>
                </button>
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('orders')">
                    <div class="mobile360-quick-icon m-bg-warning"><i class="fa fa-bar-chart"/></div>
                    <span class="mobile360-quick-label">Orders</span>
                </button>
                <button class="mobile360-quick-btn" t-on-click="() => this.navigateTo('profile')">
                    <div class="mobile360-quick-icon m-bg-purple"><i class="fa fa-cog"/></div>
                    <span class="mobile360-quick-label">Settings</span>
                </button>
            </div>
        </div>

        <!-- ── Team Locations ────────────────────────────────────────── -->
        <div class="mobile360-section" style="margin-top:4px;">
            <div class="mobile360-section-header">
                <span class="mobile360-section-title">
                    <i class="fa fa-map-marker" style="color:#4361ee;margin-right:6px;"/>Team Locations
                </span>
                <span class="mobile360-section-link" style="cursor:default;">Today</span>
            </div>

            <t t-if="teamLocationsWithGps.length">
                <div class="mobile360-list">
                    <t t-foreach="teamLocationsWithGps" t-as="loc" t-key="loc.employee_id">
                        <div class="mobile360-list-item">
                            <!-- Avatar -->
                            <div class="mobile360-list-icon"
                                t-attf-style="background:{{getAvatarGradient(loc.employee_name)}};font-weight:800;font-size:13px;">
                                <t t-esc="getInitials(loc.employee_name)"/>
                            </div>

                            <!-- Info -->
                            <div class="mobile360-list-content">
                                <div class="mobile360-list-title"><t t-esc="loc.employee_name"/></div>
                                <div class="mobile360-list-sub">
                                    <t t-if="loc.customer">
                                        <i class="fa fa-building-o" style="margin-right:3px;"/>
                                        <t t-esc="loc.customer"/>
                                        <span style="margin:0 4px;opacity:0.4;">·</span>
                                    </t>
                                    <span style="font-family:monospace;font-size:11px;">
                                        <t t-esc="loc.latitude.toFixed ? loc.latitude.toFixed(4) : loc.latitude"/>°,
                                        <t t-esc="loc.longitude.toFixed ? loc.longitude.toFixed(4) : loc.longitude"/>°
                                    </span>
                                </div>
                            </div>

                            <!-- Right: status badge + map link -->
                            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;">
                                <t t-if="loc.is_active">
                                    <span class="mobile360-badge success" style="font-size:9px;">
                                        <span style="width:6px;height:6px;border-radius:50%;background:#06d6a0;display:inline-block;margin-right:3px;animation:m-pulse 2s ease-in-out infinite;"/>
                                        Active
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="mobile360-badge muted" style="font-size:9px;">Off</span>
                                </t>
                                <a t-att-href="teamMemberMapsUrl(loc.latitude, loc.longitude)"
                                    target="_blank" class="mobile360-location-btn-sm">
                                    <i class="fa fa-map-marker"/>
                                </a>
                            </div>
                        </div>
                    </t>
                </div>
            </t>

            <t t-elif="!state.teamLocations.length">
                <div class="mobile360-empty" style="padding:28px 0;">
                    <div class="mobile360-empty-icon" style="background:linear-gradient(135deg,#4361ee,#3a0ca3);color:#fff;width:44px;height:44px;font-size:18px;">
                        <i class="fa fa-map-o"/>
                    </div>
                    <div class="mobile360-empty-title" style="font-size:14px;">No GPS Data Yet</div>
                    <div class="mobile360-empty-sub" style="font-size:12px;">Locations appear when team members check in or start a visit</div>
                </div>
            </t>

            <t t-else="">
                <div class="mobile360-empty" style="padding:28px 0;">
                    <div class="mobile360-empty-icon" style="background:linear-gradient(135deg,#64748b,#94a3b8);color:#fff;width:44px;height:44px;font-size:18px;">
                        <i class="fa fa-location-arrow"/>
                    </div>
                    <div class="mobile360-empty-title" style="font-size:14px;">Locations Not Shared</div>
                    <div class="mobile360-empty-sub" style="font-size:12px;">Team members haven't shared GPS locations today</div>
                </div>
            </t>
        </div>

        <div class="m-spacer-16"/>
    </t>

</t>

</templates>
