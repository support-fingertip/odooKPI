<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ============================================================
     EMPLOYEE 360 — MOBILE ORDERS SCREEN  v2.0
     Premium sales orders list with line-item detail sheet
     ============================================================ -->

<t t-name="employee_mobile.MobileOrders">

    <t t-if="state.loading">
        <div class="mobile360-loading">
            <div class="mobile360-spinner"/>
            <span class="mobile360-loading-text">Loading orders…</span>
        </div>
    </t>

    <t t-else="">

        <!-- ── Revenue Hero ────────────────────────────────── -->
        <div style="background:linear-gradient(135deg,#f72585,#b5179e);padding:20px 16px 34px;position:relative;overflow:hidden;">
            <div class="mobile360-hero-decor"/>
            <div style="font-size:13px;color:rgba(255,255,255,0.85);font-weight:700;letter-spacing:0.3px;margin-bottom:14px;">
                <i class="fa fa-shopping-cart" style="margin-right:6px;"/>Sales Orders
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
                <div style="background:rgba(255,255,255,0.15);border-radius:14px;padding:14px 10px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:26px;font-weight:900;color:#fff;line-height:1;"><t t-esc="state.stats.total"/></div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-top:5px;">Total</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:14px;padding:14px 10px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:26px;font-weight:900;color:#fff;line-height:1;"><t t-esc="state.stats.confirmed"/></div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-top:5px;">Confirmed</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:14px;padding:14px 10px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:17px;font-weight:900;color:#fff;line-height:1;"><t t-esc="fmtMoney(state.stats.amount)"/></div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.75);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-top:5px;">Revenue</div>
                </div>
            </div>
        </div>

        <!-- ── List Area ───────────────────────────────────── -->
        <div style="padding:0 16px;margin-top:-16px;">

            <!-- Search -->
            <div class="mobile360-search-bar">
                <i class="fa fa-search mobile360-search-icon"/>
                <input class="mobile360-search-input" type="search" placeholder="Search order or customer…"
                    t-on-input="onSearchInput"/>
            </div>

            <!-- Period chips -->
            <div class="mobile360-chips">
                <t t-foreach="[['today','Today'],['week','Week'],['month','Month'],['all','All']]" t-as="f" t-key="f[0]">
                    <button t-attf-class="mobile360-chip {{state.filter === f[0] ? 'active' : ''}}"
                        t-on-click="() => this.setFilter(f[0])"><t t-esc="f[1]"/></button>
                </t>
            </div>

            <!-- Status chips -->
            <div class="mobile360-chips" style="margin-bottom:14px;">
                <t t-foreach="[['all','All'],['sale','Confirmed'],['draft','Draft'],['done','Done'],['cancel','Cancelled']]" t-as="s" t-key="s[0]">
                    <button t-attf-class="mobile360-chip {{state.statusFilter === s[0] ? 'active' : ''}}"
                        t-on-click="() => this.setStatusFilter(s[0])"><t t-esc="s[1]"/></button>
                </t>
            </div>

            <!-- Count -->
            <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:12px;">
                <t t-esc="state.filtered.length"/> orders
            </div>

            <!-- Empty -->
            <t t-if="!state.filtered.length">
                <div class="mobile360-empty" style="padding:48px 0;">
                    <div class="mobile360-empty-icon" style="background:linear-gradient(135deg,#f72585,#b5179e);color:#fff;">
                        <i class="fa fa-shopping-cart"/>
                    </div>
                    <div class="mobile360-empty-title">No Orders Found</div>
                    <div class="mobile360-empty-sub">Try changing the date or status filter</div>
                </div>
            </t>

            <!-- ── Order Cards ────────────────────────────── -->
            <t t-foreach="state.filtered" t-as="order" t-key="order.id">
                <div class="mobile360-order-card" t-on-click="() => this.openOrderDetail(order)"
                    style="position:relative;overflow:hidden;cursor:pointer;">

                    <!-- Status left accent -->
                    <div t-attf-style="position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:4px 0 0 4px;background:{{order.state === 'sale' ? '#06d6a0' : order.state === 'done' ? '#4361ee' : order.state === 'cancel' ? '#ef233c' : '#f77f00'}};"/>

                    <div class="mobile360-order-header" style="padding-left:12px;">
                        <div style="flex:1;min-width:0;">
                            <div class="mobile360-order-number"><t t-esc="order.name"/></div>
                            <div class="mobile360-order-partner"><t t-esc="order.partner_id?.[1] || '—'"/></div>
                            <t t-if="isManager and order.user_id">
                                <div style="font-size:11px;color:#7209b7;font-weight:600;margin-top:2px;">
                                    <i class="fa fa-user" style="margin-right:3px;"/><t t-esc="order.user_id?.[1]"/>
                                </div>
                            </t>
                        </div>
                        <div style="text-align:right;flex-shrink:0;">
                            <div class="mobile360-order-amount"><t t-esc="fmtMoney(order.amount_total)"/></div>
                            <span t-attf-class="mobile360-badge {{statusClass(order.state)}}" style="margin-top:5px;">
                                <t t-esc="statusLabel(order.state)"/>
                            </span>
                        </div>
                    </div>

                    <div class="mobile360-order-footer" style="padding-left:12px;">
                        <span style="font-size:11px;color:#94a3b8;font-weight:600;">
                            <i class="fa fa-calendar-o" style="margin-right:3px;"/><t t-esc="fmtDateTime(order.date_order)"/>
                        </span>
                        <span style="font-size:11px;color:#94a3b8;font-weight:600;">
                            <i class="fa fa-list-ol" style="margin-right:3px;"/>
                            <t t-esc="(order.order_line || []).length"/> items
                        </span>
                    </div>
                </div>
            </t>

            <div style="height:24px;"/>
        </div>

        <!-- ── Order Detail Bottom Sheet ──────────────────── -->
        <t t-if="state.showOrderDetail">
            <div class="mobile360-overlay" t-on-click.self="closeOrderDetail">
                <div class="mobile360-sheet" style="max-height:92vh;">
                    <div class="mobile360-sheet-handle"/>

                    <div class="mobile360-sheet-header">
                        <div>
                            <span class="mobile360-sheet-title"><t t-esc="state.selectedOrder?.name"/></span>
                        </div>
                        <button class="mobile360-sheet-close" t-on-click="closeOrderDetail">
                            <i class="fa fa-times"/>
                        </button>
                    </div>

                    <div class="mobile360-sheet-body" style="padding:0;overflow-y:auto;">

                        <!-- Order hero -->
                        <div style="background:linear-gradient(135deg,#f72585,#b5179e);padding:20px;color:#fff;position:relative;overflow:hidden;">
                            <div class="mobile360-hero-decor" style="opacity:0.3;"/>
                            <div style="font-size:11px;color:rgba(255,255,255,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:5px;">
                                Customer
                            </div>
                            <div style="font-size:20px;font-weight:900;line-height:1.2;">
                                <t t-esc="state.selectedOrder?.partner_id?.[1]"/>
                            </div>
                            <div style="font-size:12px;color:rgba(255,255,255,0.75);margin-top:6px;">
                                <i class="fa fa-calendar-o" style="margin-right:4px;"/>
                                <t t-esc="fmtDateTime(state.selectedOrder?.date_order)"/>
                            </div>
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:14px;">
                                <div style="font-size:28px;font-weight:900;">
                                    <t t-esc="fmtMoney(state.selectedOrder?.amount_total)"/>
                                </div>
                                <span t-attf-class="mobile360-badge {{statusClass(state.selectedOrder?.state)}}"
                                    style="background:rgba(255,255,255,0.2);color:#fff;border:1px solid rgba(255,255,255,0.35);font-size:13px;padding:6px 12px;">
                                    <t t-esc="statusLabel(state.selectedOrder?.state)"/>
                                </span>
                            </div>
                        </div>

                        <!-- Line items -->
                        <t t-if="state.orderDetailBusy">
                            <div class="mobile360-loading" style="padding:32px;">
                                <div class="mobile360-spinner"/>
                            </div>
                        </t>
                        <t t-else="">
                            <div style="padding:16px;">
                                <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;">
                                    <i class="fa fa-list" style="margin-right:5px;"/>Order Lines
                                </div>

                                <t t-if="!state.orderLines.length">
                                    <div style="text-align:center;padding:24px;color:#94a3b8;font-size:13px;background:#f8fafc;border-radius:12px;">
                                        No line items found
                                    </div>
                                </t>

                                <t t-foreach="state.orderLines" t-as="line" t-key="line.id">
                                    <div style="display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid #f1f5f9;">
                                        <div style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#f72585,#b5179e);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;flex-shrink:0;">
                                            <i class="fa fa-cube"/>
                                        </div>
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:13px;font-weight:700;color:#0f172a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                                <t t-esc="line.product_id?.[1]"/>
                                            </div>
                                            <div style="font-size:12px;color:#64748b;margin-top:3px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                                <span><t t-esc="line.product_uom_qty"/> × ₹<t t-esc="line.price_unit"/></span>
                                                <t t-if="line.scheme_discount">
                                                    <span style="background:#dcfce7;color:#166534;padding:1px 6px;border-radius:6px;font-size:10px;font-weight:700;">
                                                        -<t t-esc="line.scheme_discount"/>%
                                                    </span>
                                                </t>
                                            </div>
                                        </div>
                                        <div style="font-size:14px;font-weight:800;color:#0f172a;flex-shrink:0;white-space:nowrap;">
                                            ₹<t t-esc="Math.round(line.price_subtotal or 0).toLocaleString('en-IN')"/>
                                        </div>
                                    </div>
                                </t>

                                <!-- Grand total -->
                                <t t-if="state.orderLines.length">
                                    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 0 0;border-top:2px solid #e2e8f0;margin-top:6px;">
                                        <div style="font-size:14px;font-weight:700;color:#475569;">Grand Total</div>
                                        <div style="font-size:22px;font-weight:900;color:#f72585;">
                                            <t t-esc="fmtMoney(state.selectedOrder?.amount_total)"/>
                                        </div>
                                    </div>
                                </t>

                                <div style="height:20px;"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </t>
</t>

</templates>
